import { Palette } from "std-widgets.slint";

export component FocusRing inherits Rectangle {
    background: transparent;
    border-width: 2px;
    border-color: Palette.accent-background;
    border-radius: 6px;
}

export component ClickArea inherits Rectangle {
    in property <bool> enabled: true;
    in property <string> label;
    in property <bool> show-focus-ring: true;
    in property <length> ring-radius: 6px;
    out property <bool> has-hover: touch.has-hover;
    out property <bool> pressed: touch.pressed;
    out property <bool> has-focus: fs.has-focus;

    callback clicked();

    accessible-role: button;
    accessible-enabled: root.enabled;
    accessible-label: root.label;
    accessible-action-default => {
        if (root.enabled) {
            root.clicked();
        }
    }
    forward-focus: fs;

    fs := FocusScope {
        x: 0;
        width: 0;
        enabled: root.enabled;
        key-pressed(event) => {
            if (root.enabled && (event.text == " " || event.text == "\n")) {
                root.clicked();
                return accept;
            }
            return reject;
        }
    }

    touch := TouchArea {
        enabled: root.enabled;
        mouse-cursor: root.enabled ? pointer : default;
        clicked => {
            root.clicked();
        }
    }

    @children

    if root.show-focus-ring && fs.has-focus: FocusRing {
        width: 100%;
        height: 100%;
        border-radius: root.ring-radius;
    }
}

export component ListItemArea inherits Rectangle {
    in property <bool> enabled: true;
    in property <string> label;
    in property <bool> selected: false;
    in property <int> index: -1;
    in property <bool> show-focus-ring: true;
    in property <length> ring-radius: 6px;
    in property <length> ring-inset: 0;
    out property <bool> has-hover: touch.has-hover;
    out property <bool> pressed: touch.pressed;
    out property <bool> has-focus: fs.has-focus;

    callback clicked();

    accessible-role: list-item;
    accessible-enabled: root.enabled;
    accessible-label: root.label;
    accessible-item-selectable: true;
    accessible-item-selected: root.selected;
    accessible-item-index: root.index;
    accessible-action-default => {
        if (root.enabled) {
            root.clicked();
        }
    }
    forward-focus: fs;

    fs := FocusScope {
        x: 0;
        width: 0;
        enabled: root.enabled;
        key-pressed(event) => {
            if (root.enabled && (event.text == " " || event.text == "\n")) {
                root.clicked();
                return accept;
            }
            return reject;
        }
    }

    touch := TouchArea {
        enabled: root.enabled;
        mouse-cursor: root.enabled ? pointer : default;
        clicked => {
            root.clicked();
        }
    }

    @children

    if root.show-focus-ring && fs.has-focus: FocusRing {
        x: root.ring-inset;
        y: root.ring-inset;
        width: root.width - root.ring-inset * 2;
        height: root.height - root.ring-inset * 2;
        border-radius: root.ring-radius;
    }
}
