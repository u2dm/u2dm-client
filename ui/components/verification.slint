import {
    Button,
    Palette,
} from "std-widgets.slint";

import { VerificationPhase } from "../enums.slint";
import { VerificationView } from "../views.slint";

export component VerificationDialog inherits Rectangle {
    background: Colors.black.transparentize(0.4);

    callback accept-verification();
    callback confirm-verification();
    callback reject-verification();
    callback dismissed();

    HorizontalLayout {
        alignment: center;

        VerticalLayout {
            alignment: center;

            Rectangle {
                max-width: 480px;
                background: Palette.alternate-background;
                border-radius: 8px;

                VerticalLayout {
                    padding: 24px;
                    spacing: 16px;

                    Text {
                        text: @tr("Device Verification");
                        font-size: 20px;
                        font-weight: 700;
                        horizontal-alignment: center;
                    }

                    if VerificationView.step == VerificationPhase.requested: VerticalLayout {
                        spacing: 12px;

                        Text {
                            text: VerificationView.is-self ? @tr("Verify this session from your other device") : @tr("Verification request from {}", VerificationView.sender);
                            font-size: 14px;
                            horizontal-alignment: center;
                            wrap: word-wrap;
                        }

                        HorizontalLayout {
                            alignment: center;
                            spacing: 12px;

                            Button {
                                text: @tr("Accept");
                                clicked => {
                                    root.accept-verification();
                                }
                            }

                            Button {
                                text: @tr("Decline");
                                clicked => {
                                    root.reject-verification();
                                    root.dismissed();
                                }
                            }
                        }
                    }

                    if VerificationView.step == VerificationPhase.emojis: VerticalLayout {
                        spacing: 12px;

                        Text {
                            text: @tr("Confirm the emojis below match the other device:");
                            font-size: 14px;
                            horizontal-alignment: center;
                            wrap: word-wrap;
                        }

                        HorizontalLayout {
                            alignment: center;
                            spacing: 4px;

                            for emoji in VerificationView.emojis: VerticalLayout {
                                width: 56px;
                                spacing: 4px;

                                Text {
                                    text: emoji.symbol;
                                    font-size: 28px;
                                    horizontal-alignment: center;
                                }

                                Text {
                                    text: emoji.description;
                                    font-size: 10px;
                                    horizontal-alignment: center;
                                    color: Palette.foreground.transparentize(0.4);
                                }
                            }
                        }

                        HorizontalLayout {
                            alignment: center;
                            spacing: 12px;

                            Button {
                                text: @tr("They match");
                                clicked => {
                                    root.confirm-verification();
                                }
                            }

                            Button {
                                text: @tr("They don't match");
                                clicked => {
                                    root.reject-verification();
                                    root.dismissed();
                                }
                            }
                        }
                    }

                    if VerificationView.step == VerificationPhase.confirming: VerticalLayout {
                        spacing: 12px;

                        Text {
                            text: @tr("Waiting for the other device to confirm...");
                            font-size: 14px;
                            horizontal-alignment: center;
                        }
                    }

                    if VerificationView.step == VerificationPhase.done: VerticalLayout {
                        spacing: 12px;

                        Text {
                            text: @tr("Verification successful!");
                            font-size: 16px;
                            font-weight: 600;
                            horizontal-alignment: center;
                            color: Colors.green;
                        }

                        HorizontalLayout {
                            alignment: center;

                            Button {
                                text: @tr("Done");
                                clicked => {
                                    root.dismissed();
                                }
                            }
                        }
                    }

                    if VerificationView.step == VerificationPhase.cancelled: VerticalLayout {
                        spacing: 12px;

                        Text {
                            text: @tr("Verification cancelled");
                            font-size: 16px;
                            font-weight: 600;
                            horizontal-alignment: center;
                            color: Colors.red;
                        }

                        if VerificationView.error != "": Text {
                            text: VerificationView.error;
                            font-size: 13px;
                            horizontal-alignment: center;
                            color: Palette.foreground.transparentize(0.4);
                        }

                        HorizontalLayout {
                            alignment: center;

                            Button {
                                text: @tr("Dismiss");
                                clicked => {
                                    root.dismissed();
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
