import {
    Button,
    LineEdit,
    Palette,
} from "std-widgets.slint";

import { BrandTitle, StatusText, ErrorText, LoginStatus } from "./common.slint";
import { LoginView } from "../../views.slint";

export component HomeserverScreen inherits VerticalLayout {
    alignment: center;
    padding: 24px;
    spacing: 12px;

    in-out property <string> input-homeserver: "matrix.org";

    private property <bool> is-checking: LoginView.status == "checking-server";

    callback check-server(string);

    function submit() {
        if (!root.is-checking && root.input-homeserver != "") {
            root.check-server(root.input-homeserver);
        }
    }

    BrandTitle { }

    Text {
        text: @tr("Enter your homeserver address");
        font-size: 14px;
        horizontal-alignment: center;
        color: Palette.foreground.transparentize(0.3);
    }

    HorizontalLayout {
        alignment: center;

        VerticalLayout {
            spacing: 12px;
            max-width: 320px;

            LineEdit {
                text <=> root.input-homeserver;
                placeholder-text: @tr("Homeserver (e.g. matrix.org)");
                enabled: !root.is-checking;
                accepted => {
                    root.submit();
                }
            }

            Button {
                text: root.is-checking ? @tr("Checking...") : @tr("Continue");
                enabled: !root.is-checking && root.input-homeserver != "";
                clicked => {
                    root.submit();
                }
            }
        }
    }

    if LoginView.status != "": StatusText {
        text: LoginStatus.label(LoginView.status);
    }

    if LoginView.error != "": ErrorText {
        text: LoginView.error;
    }
}
