import { BrandTitle, StatusText, ErrorText, LoginStatus } from "./common.slint";

export component LoadingScreen inherits VerticalLayout {
    alignment: center;
    padding: 24px;
    spacing: 16px;

    in property <string> loading-status: "";
    in property <string> loading-error: "";

    BrandTitle { }

    if root.loading-status != "": StatusText {
        text: LoginStatus.label(root.loading-status);
    }

    if root.loading-error != "": ErrorText {
        text: root.loading-error;
    }
}
