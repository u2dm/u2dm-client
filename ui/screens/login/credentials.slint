import {
    Button,
    LineEdit,
    Palette,
} from "std-widgets.slint";

import { LoginRequest } from "./types.slint";
import { BrandTitle, StatusText, ErrorText, LoginStatus } from "./common.slint";

export component CredentialsScreen inherits VerticalLayout {
    alignment: center;
    padding: 24px;
    spacing: 8px;

    in property <string> resolved-homeserver: "";
    in property <string> login-method: "";
    in property <string> login-status: "";
    in property <string> login-error: "";
    in-out property <string> input-username: "";
    in-out property <string> input-password: "";

    private property <bool> is-logging-in: root.login-status != "";
    private property <bool> is-oauth-pending: root.login-status == "opening-browser" || root.login-status == "waiting-auth";

    callback login-password(LoginRequest);
    callback login-oauth();
    callback cancel-oauth();
    callback back();

    function submit-password() {
        if (!root.is-logging-in && root.input-username != "" && root.input-password != "") {
            root.login-password({
                homeserver: root.resolved-homeserver,
                username: root.input-username,
                password: root.input-password,
            });
        }
    }

    BrandTitle { }

    Text {
        text: @tr("Server: {}", root.resolved-homeserver);
        font-size: 14px;
        horizontal-alignment: center;
        color: Palette.foreground.transparentize(0.3);
    }

    if root.login-method == "password" || root.login-method == "both": VerticalLayout {
        spacing: 8px;

        HorizontalLayout {
            alignment: center;

            LineEdit {
                text <=> root.input-username;
                placeholder-text: @tr("Username");
                horizontal-stretch: 0;
                max-width: root.width;
                enabled: !root.is-logging-in;
                accepted => {
                    root.submit-password();
                }
            }
        }

        HorizontalLayout {
            alignment: center;

            LineEdit {
                text <=> root.input-password;
                placeholder-text: @tr("Password");
                input-type: password;
                horizontal-stretch: 0;
                max-width: root.width;
                enabled: !root.is-logging-in;
                accepted => {
                    root.submit-password();
                }
            }
        }

        HorizontalLayout {
            alignment: center;

            Button {
                text: root.is-logging-in ? @tr("Logging in...") : @tr("Log in");
                max-width: root.width;
                enabled: !root.is-logging-in && root.input-username != "" && root.input-password != "";
                clicked => {
                    root.submit-password();
                }
            }
        }
    }

    if root.login-method == "oauth" || root.login-method == "both": HorizontalLayout {
        alignment: center;

        Button {
            text: @tr("Log in with browser");
            enabled: !root.is-logging-in;
            clicked => {
                root.login-oauth();
            }
        }
    }

    if root.is-oauth-pending: HorizontalLayout {
        alignment: center;

        Button {
            text: @tr("Cancel");
            clicked => {
                root.cancel-oauth();
            }
        }
    }

    HorizontalLayout {
        alignment: center;

        Button {
            text: @tr("Back");
            enabled: !root.is-logging-in;
            clicked => {
                root.back();
            }
        }
    }

    if root.login-status != "": StatusText {
        text: LoginStatus.label(root.login-status);
    }

    if root.login-error != "": ErrorText {
        text: root.login-error;
    }
}
