import {
    RoomEntry,
    SpaceEntry,
    MessageEntry,
    SendMessageRequest,
    SaveFileRequest,
} from "components/types.slint";
import { Palette } from "std-widgets.slint";
import { IconDisplay, IconSet } from "@lucide";
import { Sidebar } from "components/sidebar.slint";
import { Drawer } from "components/drawer.slint";
import { TimelineView } from "components/timeline/timeline-view.slint";
import { ClickArea } from "../../components/a11y.slint";

export component ChatScreen inherits Rectangle {
    in property <string> user-id: "";
    in property <string> user-initial: "";
    in property <image> user-avatar;
    in property <bool> user-has-avatar: false;
    in property <string> connection-status: "disconnected";
    in property <[RoomEntry]> rooms: [];
    in property <[SpaceEntry]> spaces: [];
    in property <[SpaceEntry]> subspaces: [];
    in property <[MessageEntry]> timeline: [];
    in property <string> toast-message: "";
    in property <string> saved-file-path: "";
    in property <string> timeline-status: "";
    in property <bool> timeline-retryable: false;
    in property <int> new-messages-count: 0;
    in property <int> prepend-token: 0;
    in property <bool> backwards-loading: false;
    in property <bool> forwards-loading: false;
    in property <string> selected-room-id: "";
    in property <string> selected-room-name: "";
    in property <int> selected-room-members: 0;
    in property <string> selected-space-id: "";
    in property <string> selected-subspace-id: "";
    in-out property <string> input-message: "";

    callback select-room(string);
    callback select-space(string);
    callback select-subspace(string);
    callback move-space(int, int);
    callback logout();
    callback send-message(SendMessageRequest);
    callback open-media(string);
    callback save-file(SaveFileRequest);
    callback request-media(string);
    callback dismiss-toast();
    callback scroll-position-changed(bool, bool);
    callback paginate-backwards();
    callback paginate-forwards();
    callback jump-to-latest();
    callback retry-timeline();

    property <length> sidebar-width: 340px;
    property <length> divider-width: 4px;
    property <length> min-sidebar-width: 260px;
    property <length> max-sidebar-width: 500px;
    property <length> subrail-width: 68px;
    property <length> total-sidebar-width: root.sidebar-width
        + (root.subspaces.length > 0 ? root.subrail-width : 0);
    property <bool> drawer-open: false;

    Sidebar {
        x: 0;
        y: 0;
        width: root.total-sidebar-width;
        height: root.height;
        subrail-width: root.subrail-width;
        rooms: root.rooms;
        spaces: root.spaces;
        subspaces: root.subspaces;
        selected-room-id: root.selected-room-id;
        selected-space-id: root.selected-space-id;
        selected-subspace-id: root.selected-subspace-id;
        select-room(id) => {
            root.select-room(id);
        }
        select-space(id) => {
            root.select-space(id);
        }
        select-subspace(id) => {
            root.select-subspace(id);
        }
        move-space(from, to) => {
            root.move-space(from, to);
        }
        menu-clicked => {
            root.drawer-open = true;
        }
    }

    TimelineView {
        x: root.total-sidebar-width;
        y: 0;
        width: root.width - root.total-sidebar-width;
        height: root.height;
        selected-room-name: root.selected-room-name;
        selected-room-id: root.selected-room-id;
        selected-room-members: root.selected-room-members;
        timeline: root.timeline;
        timeline-status: root.timeline-status;
        timeline-retryable: root.timeline-retryable;
        new-messages-count: root.new-messages-count;
        prepend-token: root.prepend-token;
        backwards-loading: root.backwards-loading;
        forwards-loading: root.forwards-loading;
        input-message <=> root.input-message;
        send-message(req) => {
            root.send-message(req);
        }
        open-media(id) => {
            root.open-media(id);
        }
        save-file(req) => {
            root.save-file(req);
        }
        request-media(id) => {
            root.request-media(id);
        }
        scroll-position-changed(at-top, at-bottom) => {
            root.scroll-position-changed(at-top, at-bottom);
        }
        paginate-backwards => {
            root.paginate-backwards();
        }
        paginate-forwards => {
            root.paginate-forwards();
        }
        jump-to-latest => {
            root.jump-to-latest();
        }
        retry => {
            root.retry-timeline();
        }
    }

    TouchArea {
        x: root.total-sidebar-width - root.divider-width / 2;
        y: 0;
        width: root.divider-width;
        height: root.height;
        mouse-cursor: col-resize;
        moved => {
            root.sidebar-width = clamp(
                    root.sidebar-width + self.mouse-x - self.pressed-x,
                    root.min-sidebar-width,
                    root.max-sidebar-width,
                );
        }
    }

    if root.toast-message != "": Rectangle {
        x: root.total-sidebar-width + (root.width - root.total-sidebar-width - self.width) / 2;
        y: root.height - self.height - 16px;
        width: min(root.width - root.total-sidebar-width - 32px, 500px);
        height: toast-layout.preferred-height;
        border-radius: 8px;
        background: Palette.alternate-background;
        drop-shadow-blur: 8px;
        drop-shadow-color: Palette.foreground.transparentize(0.8);
        drop-shadow-offset-y: 2px;

        toast-layout := HorizontalLayout {
            padding: 12px;
            spacing: 8px;
            alignment: space-between;

            Text {
                text: root.toast-message == "file-saved"
                    ? @tr("File saved to {}", root.saved-file-path)
                    : root.toast-message;
                color: root.toast-message == "file-saved"
                    ? Palette.foreground
                    : Colors.tomato.mix(Palette.foreground, 60%);
                wrap: word-wrap;
                vertical-alignment: center;
            }

            ClickArea {
                width: 24px;
                height: 24px;
                ring-radius: 6px;
                label: @tr("Dismiss");
                clicked => {
                    root.dismiss-toast();
                }
                IconDisplay {
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    icon: IconSet.X;
                    size: 16px;
                    stroke: Palette.foreground.transparentize(0.4);
                }
            }
        }
    }

    Drawer {
        x: 0;
        y: 0;
        width: root.width;
        height: root.height;
        user-id: root.user-id;
        user-initial: root.user-initial;
        user-avatar: root.user-avatar;
        user-has-avatar: root.user-has-avatar;
        connection-status: root.connection-status;
        open <=> root.drawer-open;
        add-account => {
        }
        logout => {
            root.logout();
        }
    }
}
