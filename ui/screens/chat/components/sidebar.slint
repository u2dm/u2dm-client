import {
    Button,
    Palette,
} from "std-widgets.slint";

import { RoomEntry, SpaceEntry } from "./types.slint";
import { SpaceRail } from "./space-rail.slint";

export component Sidebar inherits Rectangle {
    background: Palette.alternate-background;

    in property <string> user-id: "";
    in property <string> connection-status: "disconnected";
    in property <[RoomEntry]> rooms: [];
    in property <[SpaceEntry]> spaces: [];
    in-out property <string> selected-room-id: "";
    in-out property <string> selected-room-name: "";
    in-out property <string> selected-space-id: "";

    callback select-room(string);
    callback select-space(string);
    callback logout();

    pure function status-indicator-color(status: string) -> color {
        if status == "connected" {
            return Palette.accent-background;
        }
        if status == "connecting" {
            return Palette.accent-background.transparentize(0.5);
        }
        if status == "error" {
            return Palette.foreground.mix(Colors.red, 0.6);
        }
        return Palette.border;
    }

    pure function preview-label(kind: string, body: string) -> string {
        if kind == "image" {
            return @tr("📷 Photo");
        }
        if kind == "video" {
            return @tr("🎬 Video");
        }
        if kind == "audio" {
            return @tr("🎵 Audio");
        }
        if kind == "file" {
            return @tr("📎 {}", body);
        }
        if kind == "location" {
            return @tr("📍 Location");
        }
        if kind == "encrypted" {
            return @tr("🔒 Encrypted message");
        }
        if kind == "sticker" {
            return @tr("Sticker");
        }
        return body;
    }

    property <length> header-height: 40px;
    property <length> spacing: 4px;
    property <length> row-height: 60px;
    property <length> rail-width: 72px;

    HorizontalLayout {
        SpaceRail {
            width: root.rail-width;
            spaces: root.spaces;
            selected-space-id <=> root.selected-space-id;
            select-space(id) => {
                root.select-space(id);
            }
        }

        room-column := Rectangle {
            HorizontalLayout {
                x: 0;
                y: 0;
                width: parent.width;
                height: root.header-height;
                spacing: 8px;
                padding-left: 8px;
                padding-right: 8px;

                Rectangle {
                    width: 10px;
                    height: 10px;
                    border-radius: 5px;
                    background: root.status-indicator-color(root.connection-status);
                }

                Text {
                    text: root.user-id;
                    font-size: 12px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    color: Palette.foreground.transparentize(0.5);
                }

                Button {
                    text: @tr("Logout");
                    clicked => {
                        root.logout();
                    }
                }
            }

            Flickable {
                x: 0;
                y: root.header-height + root.spacing;
                width: parent.width;
                height: parent.height - root.header-height - root.spacing;
                viewport-height: root.rooms.length * root.row-height;

                VerticalLayout {
                    for room in root.rooms: Rectangle {
                        height: root.row-height;
                        clip: true;
                        background: room.id == root.selected-room-id
                            ? Palette.background
                            : (touch.has-hover ? Palette.background.transparentize(0.5) : transparent);

                        property <string> sender-label: room.last-message-is-own
                            ? @tr("You")
                            : room.last-message-sender;

                        touch := TouchArea {
                            clicked => {
                                root.selected-room-name = room.name;
                                root.selected-room-id = room.id;
                                root.select-room(room.id);
                            }
                        }

                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 12px;
                            spacing: 10px;

                            VerticalLayout {
                                alignment: center;
                                spacing: 3px;

                                HorizontalLayout {
                                    spacing: 6px;

                                    Text {
                                        horizontal-stretch: 1;
                                        text: room.name;
                                        font-size: 14px;
                                        font-weight: 600;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }

                                    if room.last-message-time != "": Text {
                                        text: room.last-message-time;
                                        font-size: 11px;
                                        vertical-alignment: center;
                                        color: Palette.foreground.transparentize(0.55);
                                    }
                                }

                                HorizontalLayout {
                                    spacing: 6px;

                                    HorizontalLayout {
                                        horizontal-stretch: 1;

                                        if sender-label != "": Text {
                                            text: sender-label + ": ";
                                            font-size: 12px;
                                            vertical-alignment: center;
                                            color: Palette.accent-background;
                                            overflow: elide;
                                        }

                                        Text {
                                            horizontal-stretch: 1;
                                            text: root.preview-label(room.last-message-kind, room.last-message-body);
                                            font-size: 12px;
                                            vertical-alignment: center;
                                            overflow: elide;
                                            color: Palette.foreground.transparentize(0.4);
                                        }
                                    }

                                    if room.mentions > 0: Rectangle {
                                        y: (parent.height - self.height) / 2;
                                        width: 18px;
                                        height: 18px;
                                        border-radius: 9px;
                                        background: Palette.accent-background;

                                        Text {
                                            text: "@";
                                            font-size: 11px;
                                            font-weight: 700;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                            color: Palette.accent-foreground;
                                        }
                                    }

                                    if room.unread > 0: Rectangle {
                                        y: (parent.height - self.height) / 2;
                                        height: 18px;
                                        min-width: 18px;
                                        border-radius: 9px;
                                        background: Palette.accent-background;

                                        HorizontalLayout {
                                            padding-left: 5px;
                                            padding-right: 5px;

                                            Text {
                                                text: room.unread;
                                                font-size: 11px;
                                                font-weight: 700;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                                color: Palette.accent-foreground;
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
