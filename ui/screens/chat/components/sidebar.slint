import {
    Palette,
} from "std-widgets.slint";
import { IconDisplay, IconSet } from "@lucide";

import { RoomEntry, SpaceEntry } from "./types.slint";
import { SpaceRail } from "./space-rail.slint";
import { Fonts } from "../../../theme.slint";

export component Sidebar inherits Rectangle {
    background: Palette.alternate-background;

    in property <[RoomEntry]> rooms: [];
    in property <[SpaceEntry]> spaces: [];
    in-out property <string> selected-room-id: "";
    in-out property <string> selected-room-name: "";
    in-out property <string> selected-space-id: "";

    callback select-room(string);
    callback select-space(string);
    callback move-space(int, int);
    callback menu-clicked();

    pure function preview-label(kind: string, body: string) -> string {
        if kind == "image" {
            return @tr("📷 Photo");
        }
        if kind == "video" {
            return @tr("🎬 Video");
        }
        if kind == "audio" {
            return @tr("🎵 Audio");
        }
        if kind == "file" {
            return @tr("📎 {}", body);
        }
        if kind == "location" {
            return @tr("📍 Location");
        }
        if kind == "encrypted" {
            return @tr("🔒 Encrypted message");
        }
        if kind == "sticker" {
            return @tr("Sticker");
        }
        return body;
    }

    property <length> row-height: 60px;
    property <length> rail-width: 72px;

    HorizontalLayout {
        SpaceRail {
            width: root.rail-width;
            spaces: root.spaces;
            selected-space-id <=> root.selected-space-id;
            select-space(id) => {
                root.select-space(id);
            }
            move-space(from, to) => {
                root.move-space(from, to);
            }
            menu-clicked => {
                root.menu-clicked();
            }
        }

        room-column := Rectangle {
            VerticalLayout {
                Rectangle {
                    height: 52px;

                    search-field := Rectangle {
                        x: 8px;
                        y: (parent.height - self.height) / 2;
                        width: parent.width - 16px;
                        height: 36px;
                        background: transparent;

                        Rectangle {
                            x: 14px;
                            width: parent.width - 28px;
                            height: parent.height;

                            if search-input.text == "": Text {
                                x: 0;
                                width: 100%;
                                text: @tr("Search");
                                font-size: 14px;
                                vertical-alignment: center;
                                color: Palette.foreground.transparentize(0.5);
                            }

                            search-input := TextInput {
                                width: 100%;
                                height: 100%;
                                font-size: 14px;
                                vertical-alignment: center;
                                single-line: true;
                                color: Palette.foreground;
                                text: "";
                            }
                        }

                        search-touch := TouchArea {
                            mouse-cursor: text;
                            clicked => {
                                search-input.focus();
                            }
                        }
                    }
                }

                Flickable {
                    viewport-height: root.rooms.length * root.row-height;

                    VerticalLayout {
                    for room in root.rooms: Rectangle {
                        height: root.row-height;
                        clip: true;
                        background: room.id == root.selected-room-id
                            ? Palette.background
                            : (touch.has-hover ? Palette.background.transparentize(0.5) : transparent);

                        property <string> sender-label: room.last-message-is-own
                            ? @tr("You")
                            : room.last-message-sender;

                        touch := TouchArea {
                            clicked => {
                                root.selected-room-name = room.name;
                                root.selected-room-id = room.id;
                                root.select-room(room.id);
                            }
                        }

                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 12px;
                            spacing: 10px;

                            VerticalLayout {
                                alignment: center;
                                spacing: 3px;

                                HorizontalLayout {
                                    spacing: 6px;

                                    Text {
                                        horizontal-stretch: 1;
                                        text: room.name;
                                        font-family: Fonts.emoji;
                                        font-size: 14px;
                                        font-weight: 600;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }

                                    if room.last-message-time != "": Text {
                                        text: room.last-message-time;
                                        font-size: 11px;
                                        vertical-alignment: center;
                                        color: Palette.foreground.transparentize(0.55);
                                    }
                                }

                                HorizontalLayout {
                                    spacing: 6px;

                                    HorizontalLayout {
                                        horizontal-stretch: 1;

                                        if sender-label != "": Text {
                                            text: sender-label + ": ";
                                            font-size: 12px;
                                            vertical-alignment: center;
                                            color: Palette.accent-background;
                                            overflow: elide;
                                        }

                                        if room.last-message-edited: Rectangle {
                                            width: 16px;

                                            IconDisplay {
                                                x: 0;
                                                y: (parent.height - self.height) / 2;
                                                icon: IconSet.Pencil;
                                                size: 12px;
                                                stroke: Palette.foreground.transparentize(0.4);
                                            }
                                        }

                                        Text {
                                            horizontal-stretch: 1;
                                            text: root.preview-label(room.last-message-kind, room.last-message-body);
                                            font-family: Fonts.emoji;
                                            font-size: 12px;
                                            vertical-alignment: center;
                                            overflow: elide;
                                            color: Palette.foreground.transparentize(0.4);
                                        }
                                    }

                                    if room.mentions > 0: Rectangle {
                                        y: (parent.height - self.height) / 2;
                                        width: 18px;
                                        height: 18px;
                                        border-radius: 9px;
                                        background: Palette.accent-background;

                                        IconDisplay {
                                            x: (parent.width - self.width) / 2;
                                            y: (parent.height - self.height) / 2;
                                            icon: IconSet.AtSign;
                                            size: 12px;
                                            stroke: Palette.accent-foreground;
                                        }
                                    }

                                    if room.unread > 0: Rectangle {
                                        y: (parent.height - self.height) / 2;
                                        height: 18px;
                                        min-width: 18px;
                                        border-radius: 9px;
                                        background: Palette.accent-background;

                                        HorizontalLayout {
                                            padding-left: 5px;
                                            padding-right: 5px;

                                            Text {
                                                text: room.unread;
                                                font-size: 11px;
                                                font-weight: 700;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                                color: Palette.accent-foreground;
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
        }
    }
}
