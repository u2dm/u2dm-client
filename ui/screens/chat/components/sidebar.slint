import {
    Palette,
} from "std-widgets.slint";
import { IconDisplay, IconSet } from "@lucide";

import { RoomEntry, SpaceEntry } from "./types.slint";
import { SpaceRail } from "./space-rail.slint";
import { SubspaceRail } from "./subspace-rail.slint";
import { MessagePreview } from "./message-preview.slint";
import { ServiceLabel } from "./timeline/messages/service-message.slint";
import { Avatar } from "../../../components/avatar.slint";
import { ListItemArea } from "../../../components/a11y.slint";
import { Avatars, Fonts } from "../../../theme.slint";

export component Sidebar inherits Rectangle {
    background: Palette.alternate-background;

    in property <[RoomEntry]> rooms: [];
    in property <[SpaceEntry]> spaces: [];
    in property <[SpaceEntry]> subspaces: [];
    in-out property <string> selected-room-id: "";
    in-out property <string> selected-room-name: "";
    in-out property <int> selected-room-members: 0;
    in-out property <string> selected-space-id: "";
    in-out property <string> selected-subspace-id: "";

    callback select-room(string);
    callback select-space(string);
    callback select-subspace(string);
    callback move-space(int, int);
    callback menu-clicked();

    in property <length> subrail-width: 68px;

    property <length> row-height: 64px;
    property <length> rail-width: 72px;
    property <length> avatar-size: 48px;

    HorizontalLayout {
        SpaceRail {
            width: root.rail-width;
            spaces: root.spaces;
            selected-space-id <=> root.selected-space-id;
            select-space(id) => {
                root.select-space(id);
            }
            move-space(from, to) => {
                root.move-space(from, to);
            }
            menu-clicked => {
                root.menu-clicked();
            }
        }

        if root.subspaces.length > 0: SubspaceRail {
            width: root.subrail-width;
            subspaces: root.subspaces;
            selected-subspace-id <=> root.selected-subspace-id;
            select-subspace(id) => {
                root.select-subspace(id);
            }
        }

        room-column := Rectangle {
            VerticalLayout {
                Rectangle {
                    height: 52px;

                    search-field := Rectangle {
                        x: 8px;
                        y: (parent.height - self.height) / 2;
                        width: parent.width - 16px;
                        height: 36px;
                        background: transparent;

                        Rectangle {
                            x: 14px;
                            width: parent.width - 28px;
                            height: parent.height;

                            if search-input.text == "": Text {
                                x: 0;
                                width: 100%;
                                text: @tr("Search");
                                font-size: 14px;
                                vertical-alignment: center;
                                color: Palette.foreground.transparentize(0.5);
                            }

                            search-input := TextInput {
                                width: 100%;
                                height: 100%;
                                font-size: 14px;
                                vertical-alignment: center;
                                single-line: true;
                                color: Palette.foreground;
                                text: "";
                            }
                        }

                        search-touch := TouchArea {
                            mouse-cursor: text;
                            clicked => {
                                search-input.focus();
                            }
                        }
                    }
                }

                Flickable {
                    viewport-height: root.rooms.length * root.row-height;

                    VerticalLayout {
                    accessible-role: list;
                    accessible-label: @tr("Rooms");
                    accessible-item-count: root.rooms.length;
                    for room[idx] in root.rooms: ListItemArea {
                        height: root.row-height;
                        clip: true;
                        index: idx;
                        selected: room.id == root.selected-room-id;
                        label: room.unread > 0
                            ? @tr("{}, {} unread", room.name, room.unread)
                            : room.name;
                        ring-inset: 2px;
                        background: room.id == root.selected-room-id
                            ? Palette.background
                            : (self.has-hover ? Palette.background.transparentize(0.5) : transparent);
                        clicked => {
                            root.selected-room-name = room.name;
                            root.selected-room-members = room.members;
                            root.selected-room-id = room.id;
                            root.select-room(room.id);
                        }

                        property <string> sender-label: room.last-message-is-own
                            ? @tr("You")
                            : room.last-message-sender;
                        property <bool> is-service: room.last-message-service-kind != "";

                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 12px;
                            spacing: 10px;

                            VerticalLayout {
                                alignment: center;

                                Avatar {
                                    width: root.avatar-size;
                                    height: root.avatar-size;
                                    background: Avatars.color(room.color-index);
                                    has-image: room.has-avatar;
                                    image: room.avatar;
                                    initial: room.initial;
                                }
                            }

                            VerticalLayout {
                                alignment: center;
                                spacing: 3px;

                                HorizontalLayout {
                                    spacing: 6px;

                                    Text {
                                        horizontal-stretch: 1;
                                        text: room.name;
                                        font-family: Fonts.emoji;
                                        font-size: 14px;
                                        font-weight: 600;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }

                                    if room.last-message-time != "": Text {
                                        text: room.last-message-time;
                                        font-size: 11px;
                                        vertical-alignment: center;
                                        color: Palette.foreground.transparentize(0.55);
                                    }
                                }

                                HorizontalLayout {
                                    spacing: 6px;

                                    HorizontalLayout {
                                        horizontal-stretch: 1;

                                        if !is-service && sender-label != "": Text {
                                            text: sender-label + ": ";
                                            font-size: 12px;
                                            vertical-alignment: center;
                                            color: Palette.accent-background;
                                            overflow: elide;
                                        }

                                        if !is-service && room.last-message-edited: Rectangle {
                                            width: 16px;

                                            IconDisplay {
                                                x: 0;
                                                y: (parent.height - self.height) / 2;
                                                icon: IconSet.Pencil;
                                                size: 12px;
                                                stroke: Palette.foreground.transparentize(0.4);
                                            }
                                        }

                                        Text {
                                            horizontal-stretch: 1;
                                            text: is-service
                                                ? ServiceLabel.label(room.last-message-service-kind, sender-label, room.last-message-service-target)
                                                : MessagePreview.label(room.last-message-kind, room.last-message-body);
                                            font-family: Fonts.emoji;
                                            font-size: 12px;
                                            vertical-alignment: center;
                                            overflow: elide;
                                            color: Palette.foreground.transparentize(0.4);
                                        }
                                    }

                                    if room.mentions > 0: Rectangle {
                                        y: (parent.height - self.height) / 2;
                                        width: 18px;
                                        height: 18px;
                                        border-radius: 9px;
                                        background: Palette.accent-background;

                                        IconDisplay {
                                            x: (parent.width - self.width) / 2;
                                            y: (parent.height - self.height) / 2;
                                            icon: IconSet.AtSign;
                                            size: 12px;
                                            stroke: Palette.accent-foreground;
                                        }
                                    }

                                    if room.unread > 0: Rectangle {
                                        y: (parent.height - self.height) / 2;
                                        height: 18px;
                                        min-width: 18px;
                                        border-radius: 9px;
                                        background: Palette.accent-background;

                                        HorizontalLayout {
                                            padding-left: 5px;
                                            padding-right: 5px;

                                            Text {
                                                text: room.unread;
                                                font-size: 11px;
                                                font-weight: 700;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                                color: Palette.accent-foreground;
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
        }
    }
}
