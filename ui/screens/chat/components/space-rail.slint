import { Palette } from "std-widgets.slint";

import { SpaceEntry } from "./types.slint";

component SpaceTile inherits Rectangle {
    in property <string> label;
    in property <string> initial;
    in property <length> initial-font-size: 18px;
    in property <bool> has-avatar;
    in property <image> avatar;
    in property <int> unread;
    in property <int> mentions;
    in property <bool> selected;
    in property <bool> draggable;
    in property <bool> elevated;
    in property <bool> hidden;
    in property <bool> interactive: true;

    callback clicked();
    callback pressed-down();
    callback pressed-up();
    callback moved(length);

    height: 68px;

    content := Rectangle {
        width: 100%;
        height: 100%;
        opacity: root.hidden ? 0 : 1;
        background: touch.has-hover && !root.hidden
            ? Palette.foreground.transparentize(0.93)
            : transparent;

        Rectangle {
            x: 0;
            width: 3px;
            height: root.selected ? 36px : 0;
            y: (parent.height - self.height) / 2;
            border-radius: 1.5px;
            background: Palette.accent-background;
            animate height {
                duration: 150ms;
                easing: ease-out;
            }
        }

        avatar-circle := Rectangle {
            width: 44px;
            height: 44px;
            x: (parent.width - self.width) / 2;
            y: 5px;
            border-radius: root.selected || root.elevated ? 13px : self.width / 2;
            background: root.selected
                ? Palette.accent-background
                : Palette.accent-background.transparentize(0.85);
            clip: true;
            drop-shadow-blur: root.elevated ? 12px : 0;
            drop-shadow-color: Palette.foreground.transparentize(0.45);
            animate border-radius {
                duration: 150ms;
                easing: ease-out;
            }

            if root.has-avatar: Image {
                width: 100%;
                height: 100%;
                source: root.avatar;
                image-fit: cover;
            }

            if !root.has-avatar: Text {
                width: 100%;
                height: 100%;
                text: root.initial;
                font-size: root.initial-font-size;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
                overflow: clip;
                color: root.selected ? Palette.accent-foreground : Palette.accent-background;
            }
        }

        Text {
            x: 3px;
            y: avatar-circle.y + avatar-circle.height + 2px;
            width: parent.width - 6px;
            text: root.label;
            font-size: 9px;
            horizontal-alignment: center;
            overflow: elide;
            color: root.selected
                ? Palette.foreground
                : Palette.foreground.transparentize(0.45);
        }

        if root.unread > 0 || root.mentions > 0: Rectangle {
            x: avatar-circle.x + avatar-circle.width - self.width + 4px;
            y: avatar-circle.y - 3px;
            height: 18px;
            min-width: 18px;
            border-radius: 9px;
            background: Palette.accent-background;
            border-width: 2px;
            border-color: Palette.alternate-background;

            HorizontalLayout {
                padding-left: 5px;
                padding-right: 5px;

                Text {
                    text: root.unread > 0 ? root.unread : root.mentions;
                    font-size: 10px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    color: Palette.accent-foreground;
                }
            }
        }
    }

    touch := TouchArea {
        enabled: root.interactive;
        mouse-cursor: pointer;
        changed pressed => {
            if (self.pressed) {
                root.pressed-down();
            } else {
                root.pressed-up();
            }
        }
        moved => {
            if (root.draggable) {
                root.moved(self.mouse-y - self.pressed-y);
            }
        }
        clicked => {
            root.clicked();
        }
    }
}

export component SpaceRail inherits Rectangle {
    in property <[SpaceEntry]> spaces: [];
    in-out property <string> selected-space-id: "";

    callback select-space(string);
    callback move-space(int, int);

    property <length> row-height: 68px;
    property <length> drag-threshold: 6px;
    property <bool> dragging: false;
    property <int> drag-from: -1;
    property <length> drag-dy: 0;
    property <bool> did-drag: false;
    property <int> drag-to: clamp(
        root.drag-from + round(root.drag-dy / root.row-height),
        0,
        root.spaces.length - 1,
    );

    property <string> drag-name;
    property <string> drag-initial;
    property <image> drag-avatar;
    property <bool> drag-has-avatar;
    property <int> drag-unread;
    property <int> drag-mentions;
    property <bool> drag-selected;

    background: Palette.alternate-background.mix(Palette.background, 0.35);

    function begin-drag(idx: int, entry: SpaceEntry, selected: bool) {
        root.drag-from = idx;
        root.drag-dy = 0;
        root.did-drag = false;
        root.drag-name = entry.name;
        root.drag-initial = entry.initial;
        root.drag-avatar = entry.avatar;
        root.drag-has-avatar = entry.has-avatar;
        root.drag-unread = entry.unread;
        root.drag-mentions = entry.mentions;
        root.drag-selected = selected;
        root.dragging = true;
    }

    function update-drag(dy: length) {
        root.drag-dy = dy;
        if (dy > root.drag-threshold || dy < -root.drag-threshold) {
            root.did-drag = true;
        }
    }

    function end-drag() {
        if (root.dragging) {
            if (root.did-drag && root.drag-to != root.drag-from) {
                root.move-space(root.drag-from, root.drag-to);
            }
            root.dragging = false;
            root.drag-from = -1;
            root.drag-dy = 0;
        }
    }

    pure function drag-rank(idx: int) -> int {
        return idx < root.drag-from ? idx : idx - 1;
    }

    pure function slot-for(idx: int) -> int {
        if (!root.dragging || idx == root.drag-from) {
            return idx;
        }
        return root.drag-rank(idx) < root.drag-to
            ? root.drag-rank(idx)
            : root.drag-rank(idx) + 1;
    }

    Flickable {
        width: root.width;
        height: root.height;
        interactive: !root.dragging;
        viewport-width: root.width;
        viewport-height: (root.spaces.length + 1) * root.row-height;

        SpaceTile {
            x: 0;
            y: 0;
            width: root.width;
            height: root.row-height;
            draggable: false;
            label: @tr("All Rooms");
            initial: @tr("All");
            initial-font-size: 13px;
            selected: root.selected-space-id == "";
            pressed-down => {
                root.did-drag = false;
            }
            clicked => {
                if (!root.did-drag) {
                    root.selected-space-id = "";
                    root.select-space("");
                }
            }
        }

        for space[idx] in root.spaces: SpaceTile {
            x: 0;
            y: (root.slot-for(idx) + 1) * root.row-height;
            width: root.width;
            height: root.row-height;
            draggable: true;
            hidden: root.dragging && idx == root.drag-from;
            label: space.name;
            initial: space.initial;
            has-avatar: space.has-avatar;
            avatar: space.avatar;
            unread: space.unread;
            mentions: space.mentions;
            selected: root.selected-space-id == space.id;
            animate y {
                duration: 120ms;
                easing: ease-out;
            }
            pressed-down => {
                root.begin-drag(idx, space, root.selected-space-id == space.id);
            }
            pressed-up => {
                root.end-drag();
            }
            moved(dy) => {
                root.update-drag(dy);
            }
            clicked => {
                if (!root.did-drag) {
                    root.selected-space-id = space.id;
                    root.select-space(space.id);
                }
            }
        }

        if root.dragging: SpaceTile {
            x: 0;
            y: (root.drag-from + 1) * root.row-height + root.drag-dy;
            width: root.width;
            height: root.row-height;
            interactive: false;
            elevated: true;
            label: root.drag-name;
            initial: root.drag-initial;
            has-avatar: root.drag-has-avatar;
            avatar: root.drag-avatar;
            unread: root.drag-unread;
            mentions: root.drag-mentions;
            selected: root.drag-selected;
        }
    }
}
