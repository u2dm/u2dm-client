import { PreviewKind } from "../../../enums.slint";

export global MessagePreview {
    public pure function label(kind: PreviewKind, body: string) -> string {
        if kind == PreviewKind.image {
            return @tr("📷 Photo");
        }
        if kind == PreviewKind.video {
            return @tr("🎬 Video");
        }
        if kind == PreviewKind.audio {
            return @tr("🎵 Audio");
        }
        if kind == PreviewKind.file {
            return @tr("📎 {}", body);
        }
        if kind == PreviewKind.location {
            return @tr("📍 Location");
        }
        if kind == PreviewKind.encrypted {
            return @tr("🔒 Encrypted message");
        }
        if kind == PreviewKind.sticker {
            return @tr("Sticker");
        }
        return body;
    }
}
