import {
    Button,
    Palette,
} from "std-widgets.slint";

import {
    MessageEntry,
    SendMessageRequest,
    SaveFileRequest,
} from "./types.slint";

import { TextMessage } from "./messages/text-message.slint";
import { ImageMessage } from "./messages/image-message.slint";
import { FileMessage } from "./messages/file-message.slint";

export component TimelineView inherits Rectangle {
    background: Palette.background;

    in property <string> selected-room-name: "";
    in property <string> selected-room-id: "";
    in property <[MessageEntry]> timeline: [];
    in-out property <string> input-message: "";

    callback send-message(SendMessageRequest);
    callback open-media(string);
    callback save-file(SaveFileRequest);

    property <length> header-height: 40px;
    property <length> input-height: 40px;
    property <length> spacing: 8px;

    if root.selected-room-name == "": Text {
        text: "Select a room";
        font-size: 16px;
        color: Palette.foreground.transparentize(0.5);
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    if root.selected-room-name != "": Rectangle {
        x: 0;
        y: 0;
        width: root.width;
        height: root.header-height;
        background: Palette.alternate-background;

        Text {
            text: root.selected-room-name;
            font-size: 18px;
            font-weight: 700;
            vertical-alignment: center;
        }
    }

    if root.selected-room-name != "": Flickable {
        x: 0;
        y: root.header-height + root.spacing;
        width: root.width;
        height: root.height - root.header-height - root.input-height - root.spacing * 2;

        property <bool> auto-scroll: true;

        flicked => {
            if self.viewport-y <= -(self.viewport-height - self.height - 20px) {
                self.auto-scroll = true;
            } else {
                self.auto-scroll = false;
            }
        }

        changed viewport-height => {
            if self.auto-scroll && self.viewport-height > self.height {
                self.viewport-y = -(self.viewport-height - self.height);
            }
        }

        VerticalLayout {
            alignment: end;

            for msg in root.timeline: Rectangle {
                VerticalLayout {
                    padding-left: 8px;
                    padding-right: 8px;
                    padding-top: 4px;
                    padding-bottom: 4px;
                    spacing: 2px;

                    HorizontalLayout {
                        spacing: 8px;

                        Text {
                            text: msg.sender;
                            font-size: 13px;
                            font-weight: 600;
                        }

                        Text {
                            text: msg.timestamp;
                            font-size: 11px;
                            color: Palette.foreground.transparentize(0.5);
                            vertical-alignment: center;
                        }
                    }

                    if msg.message-type == "image": ImageMessage {
                        thumbnail: msg.thumbnail;
                        has-thumbnail: msg.has-thumbnail;
                        body: msg.body;
                        event-id: msg.event-id;
                        open-media(id) => { root.open-media(id); }
                    }

                    if msg.message-type == "file": FileMessage {
                        body: msg.body;
                        event-id: msg.event-id;
                        save-file(req) => { root.save-file(req); }
                    }

                    if msg.message-type != "image" && msg.message-type != "file": TextMessage {
                        text: msg.body;
                    }
                }
            }
        }
    }

    if root.selected-room-name != "": Rectangle {
        x: 0;
        y: root.height - root.input-height;
        width: root.width;
        height: root.input-height;
        background: Palette.alternate-background;

        HorizontalLayout {

            Rectangle {
                horizontal-stretch: 1;

                TextInput {
                    text <=> root.input-message;
                    color: Palette.foreground;
                    font-size: 14px;
                    vertical-alignment: center;
                    accepted => {
                        if root.input-message != "" {
                            root.send-message({ room-id: root.selected-room-id, body: root.input-message });
                            root.input-message = "";
                        }
                    }
                }

                if root.input-message == "": Text {
                    x: 0;
                    y: 0;
                    width: parent.width;
                    height: parent.height;
                    text: "Send a message...";
                    color: Palette.foreground.transparentize(0.5);
                    font-size: 14px;
                    vertical-alignment: center;
                    horizontal-alignment: left;
                }
            }

            Button {
                text: "Send";
                clicked => {
                    if root.input-message != "" {
                        root.send-message({ room-id: root.selected-room-id, body: root.input-message });
                        root.input-message = "";
                    }
                }
            }
        }
    }
}
