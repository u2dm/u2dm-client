import {
    Button,
    ListView,
    Palette,
} from "std-widgets.slint";

import {
    MessageEntry,
    SendMessageRequest,
    SaveFileRequest,
} from "./types.slint";

import { TextMessage } from "./messages/text-message.slint";
import { ImageMessage } from "./messages/image-message.slint";
import { FileMessage } from "./messages/file-message.slint";
import { UtdMessage } from "./messages/utd-message.slint";
import { UnsupportedMessage } from "./messages/unsupported-message.slint";

component MessageBubble inherits Rectangle {
    in property <bool> is-own;
    in property <MessageEntry> msg;
    in property <length> available-width;

    callback open-media(string);
    callback save-file(SaveFileRequest);

    property <color> own-bubble-color: Palette.accent-background.transparentize(0.4);
    property <color> other-bubble-color: Palette.alternate-background;
    property <length> bubble-max-width: available-width * 0.7;

    HorizontalLayout {
        alignment: is-own ? end : start;
        padding-left: is-own ? 0 : 8px;
        padding-right: is-own ? 8px : 0;
        padding-top: 2px;
        padding-bottom: 2px;

        if !is-own: Rectangle {
            width: 32px;
            height: 32px;
            border-radius: 16px;
            clip: true;
            background: Palette.foreground.transparentize(0.85);

            if msg.has-avatar: Image {
                source: msg.avatar;
                width: 32px;
                height: 32px;
                image-fit: cover;
            }

            if !msg.has-avatar: Text {
                width: 32px;
                height: 32px;
                text: msg.sender-initial;
                font-size: 14px;
                font-weight: 600;
                horizontal-alignment: center;
                vertical-alignment: center;
                color: Palette.foreground.transparentize(0.3);
                overflow: clip;
            }
        }

        if !is-own: Rectangle {
            width: 6px;
        }

        Rectangle {
            max-width: bubble-max-width;
            height: bubble-content.preferred-height;
            background: is-own ? own-bubble-color : other-bubble-color;
            border-radius: 12px;

            bubble-content := VerticalLayout {
                padding: 4px;
                padding-left: 10px;
                padding-right: 10px;

                if !is-own: HorizontalLayout {
                    Text {
                        text: msg.sender;
                        font-size: 12px;
                        font-weight: 700;
                        color: Palette.accent-background;
                    }
                }

                if msg.message-type == "image": ImageMessage {
                    thumbnail: msg.thumbnail;
                    has-thumbnail: msg.has-thumbnail;
                    image-width: msg.image-width;
                    image-height: msg.image-height;
                    body: msg.body;
                    event-id: msg.event-id;
                    open-media(id) => {
                        root.open-media(id);
                    }
                }

                if msg.message-type == "file": FileMessage {
                    body: msg.body;
                    event-id: msg.event-id;
                    save-file(req) => {
                        root.save-file(req);
                    }
                }

                if msg.message-type == "utd": UtdMessage { }

                if msg.message-type == "unsupported": UnsupportedMessage {
                    body: msg.body;
                }

                if msg.message-type != "image" && msg.message-type != "file" && msg.message-type != "utd" && msg.message-type != "unsupported": TextMessage {
                    text: msg.body;
                }

                HorizontalLayout {
                    alignment: end;
                    VerticalLayout {
                        alignment: end;

                        Text {
                            text: msg.timestamp;
                            font-size: 12px;
                            color: Palette.foreground.transparentize(0.5);
                            horizontal-alignment: right;
                        }
                    }
                }
            }
        }
    }
}

component TimelineContent inherits Rectangle {
    in property <[MessageEntry]> timeline: [];
    in property <bool> backwards-loading: false;
    in property <int> new-messages-count: 0;
    in property <length> available-width;

    callback open-media(string);
    callback save-file(SaveFileRequest);
    callback scroll-position-changed(bool, bool);
    callback jump-to-latest();

    clip: true;

    if root.backwards-loading: HorizontalLayout {
        x: 0;
        y: 0;
        width: parent.width;
        height: 32px;
        alignment: center;
        Text {
            text: @tr("Loading older messages...");
            font-size: 12px;
            color: Palette.foreground.transparentize(0.5);
        }
    }

    flickable := ListView {
        width: parent.width;
        height: parent.height;

        property <length> scroll-threshold: 40px;
        property <bool> auto-scroll: true;
        property <bool> programmatic-scroll: false;

        property <bool> was-at-top: false;
        property <bool> was-at-bottom: true;
        property <bool> at-top: self.viewport-y >= -self.scroll-threshold;
        property <bool> at-bottom:
            self.viewport-y <= -(self.max-scroll-y - self.scroll-threshold);

        property <int> prev-count: 0;
        property <bool> prepend-pending: false;
        property <length> saved-viewport-y: 0;
        property <int> saved-count: 0;

        property <length> max-scroll-y:
            self.viewport-height - self.visible-height;
        property <bool> scrollable:
            self.viewport-height > self.visible-height;
        property <int> item-count: root.timeline.length;
        property <bool> items-added:
            self.item-count > self.prev-count;

        changed viewport-y => {
            if self.programmatic-scroll {
                self.programmatic-scroll = false;
            } else {
                self.prepend-pending = false;
            }

            if self.scrollable {
                self.auto-scroll = self.viewport-y <= -(self.max-scroll-y - self.scroll-threshold);
            }
            if (self.at-top != self.was-at-top) || (self.at-bottom != self.was-at-bottom) {
                self.was-at-top = self.at-top;
                self.was-at-bottom = self.at-bottom;
                root.scroll-position-changed(self.at-top, self.at-bottom);
            }
        }

        changed item-count => {
            if self.scrollable {
                if self.auto-scroll {
                    self.scroll-to-bottom();
                } else if self.items-added {
                    self.anchor-scroll();
                }
            }
            self.prev-count = self.item-count;
        }

        function scroll-to-bottom() {
            self.programmatic-scroll = true;
            self.viewport-y = -self.max-scroll-y;
        }

        function anchor-scroll() {
            if !self.prepend-pending {
                self.saved-viewport-y = self.viewport-y;
                self.saved-count = self.prev-count;
                self.prepend-pending = true;
            }
            self.programmatic-scroll = true;
            self.viewport-y = self.saved-viewport-y - self.viewport-height * (self.item-count - self.saved-count) / self.item-count;
        }

        for msg in root.timeline: MessageBubble {
            is-own: msg.is-own;
            msg: msg;
            available-width: root.available-width;
            open-media(id) => {
                root.open-media(id);
            }
            save-file(req) => {
                root.save-file(req);
            }
        }
    }

    if !flickable.auto-scroll && root.timeline.length > 0: Rectangle {
        x: parent.width - self.width - 16px;
        y: parent.height - self.height - 16px;
        width: 40px;
        height: 40px;
        border-radius: 20px;
        background: Palette.alternate-background;

        Text {
            text: "∨";
            font-size: 18px;
            font-weight: 700;
            color: Palette.alternate-foreground;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        TouchArea {
            mouse-cursor: pointer;
            clicked => {
                flickable.viewport-y = -(flickable.viewport-height - flickable.visible-height);
                flickable.auto-scroll = true;
                root.jump-to-latest();
            }
        }

        if root.new-messages-count > 0: Rectangle {
            x: parent.width - self.width / 2 - 2px;
            y: -self.height / 2 + 2px;
            width: Math.max(18px, badge-text.preferred-width + 8px);
            height: 18px;
            border-radius: 9px;
            background: Palette.accent-background;

            badge-text := Text {
                text: root.new-messages-count;
                font-size: 10px;
                font-weight: 700;
                color: Palette.accent-foreground;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }
}

export component TimelineView inherits Rectangle {
    background: Palette.background;

    in property <string> selected-room-name: "";
    in property <string> selected-room-id: "";
    in property <[MessageEntry]> timeline: [];
    in property <bool> timeline-loading: false;
    in property <int> new-messages-count: 0;
    in property <bool> backwards-loading: false;
    in-out property <string> input-message: "";

    callback send-message(SendMessageRequest);
    callback open-media(string);
    callback save-file(SaveFileRequest);
    callback scroll-position-changed(bool, bool);
    callback paginate-backwards();
    callback jump-to-latest();

    property <length> header-height: 40px;
    property <length> input-height: 40px;
    property <length> spacing: 8px;

    if root.selected-room-name == "": Text {
        text: @tr("Select a room");
        font-size: 16px;
        color: Palette.foreground.transparentize(0.5);
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    if root.selected-room-name != "": Rectangle {
        x: 0;
        y: 0;
        width: root.width;
        height: root.header-height;
        background: Palette.alternate-background;

        Text {
            text: root.selected-room-name;
            font-size: 18px;
            font-weight: 700;
            vertical-alignment: center;
        }
    }

    if root.selected-room-name != "" && root.timeline-loading && root.timeline.length == 0: Text {
        x: 0;
        y: root.header-height;
        width: root.width;
        height: root.height - root.header-height - root.input-height;
        text: @tr("Loading messages...");
        font-size: 14px;
        color: Palette.foreground.transparentize(0.5);
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    if root.selected-room-name != "": TimelineContent {
        x: 0;
        y: root.header-height + root.spacing;
        width: root.width;
        height: root.height - root.header-height - root.input-height - root.spacing * 2;
        timeline: root.timeline;
        backwards-loading: root.backwards-loading;
        new-messages-count: root.new-messages-count;
        available-width: root.width;
        open-media(id) => {
            root.open-media(id);
        }
        save-file(req) => {
            root.save-file(req);
        }
        scroll-position-changed(at-top, at-bottom) => {
            root.scroll-position-changed(at-top, at-bottom);
        }
        jump-to-latest => {
            root.jump-to-latest();
        }
    }

    if root.selected-room-name != "": Rectangle {
        x: 0;
        y: root.height - root.input-height;
        width: root.width;
        height: root.input-height;
        background: Palette.alternate-background;

        HorizontalLayout {

            Rectangle {
                horizontal-stretch: 1;

                TextInput {
                    text <=> root.input-message;
                    color: Palette.foreground;
                    font-size: 14px;
                    vertical-alignment: center;
                    accepted => {
                        if root.input-message != "" {
                            root.send-message({ room-id: root.selected-room-id, body: root.input-message });
                            root.input-message = "";
                        }
                    }
                }

                if root.input-message == "": Text {
                    x: 0;
                    y: 0;
                    width: parent.width;
                    height: parent.height;
                    text: @tr("Send a message...");
                    color: Palette.foreground.transparentize(0.5);
                    font-size: 14px;
                    vertical-alignment: center;
                    horizontal-alignment: left;
                }
            }

            Button {
                text: @tr("Send");
                clicked => {
                    if root.input-message != "" {
                        root.send-message({ room-id: root.selected-room-id, body: root.input-message });
                        root.input-message = "";
                    }
                }
            }
        }
    }
}
