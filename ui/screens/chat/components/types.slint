export struct RoomEntry {
    id: string,
    name: string,
    initial: string,
    avatar: image,
    has-avatar: bool,
    color-index: int,
    members: int,
    unread: int,
    mentions: int,
    last-message-sender: string,
    last-message-kind: string,
    last-message-body: string,
    last-message-is-own: bool,
    last-message-edited: bool,
    last-message-time: string,
}

export struct SpaceEntry {
    id: string,
    name: string,
    unread: int,
    mentions: int,
    initial: string,
    avatar: image,
    has-avatar: bool,
}

export struct MessageEntry {
    unique-id: string,
    sender: string,
    pronouns: [string],
    body: string,
    timestamp: string,
    message-type: string,
    preview-kind: string,
    unsupported-kind: string,
    has-thumbnail: bool,
    thumbnail: image,
    image-width: int,
    image-height: int,
    event-id: string,
    has-avatar: bool,
    avatar: image,
    sender-initial: string,
    color-index: int,
    is-own: bool,
    edited: bool,
    has-reply: bool,
    reply-sender: string,
    reply-kind: string,
    reply-body: string,
}

export struct EmojiEntry {
    base: string,
    tones: [string],
    name: string,
}

export struct EmojiGroup {
    items: [EmojiEntry],
}

export struct EmojiInsert {
    text: string,
    caret: int,
}

export struct SendMessageRequest {
    room-id: string,
    body: string,
    reply-to: string,
}

export struct SaveFileRequest {
    event-id: string,
    filename: string,
}
