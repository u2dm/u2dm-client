import {
    Palette,
} from "std-widgets.slint";
import { IconDisplay, IconSet } from "@lucide";

import {
    MessageEntry,
    SaveFileRequest,
} from "../types.slint";

import { MessagePreview } from "../message-preview.slint";
import { ReplyQuote } from "../reply-quote.slint";
import { ServiceMessage } from "./messages/service-message.slint";
import { TextMessage } from "./messages/text-message.slint";
import { ImageMessage } from "./messages/image-message.slint";
import { FileMessage } from "./messages/file-message.slint";
import { UtdMessage } from "./messages/utd-message.slint";
import { UnsupportedMessage } from "./messages/unsupported-message.slint";
import { Avatar } from "../../../../components/avatar.slint";
import { ClickArea } from "../../../../components/a11y.slint";
import { Avatars } from "../../../../theme.slint";
import { MessageKind } from "../../../../enums.slint";

component PronounBadge inherits Rectangle {
    in property <string> text;

    width: pronoun-text.preferred-width + 10px;
    height: pronoun-text.preferred-height + 2px;
    border-radius: self.height / 2;
    background: Palette.foreground.transparentize(0.92);

    pronoun-text := Text {
        text: root.text;
        font-size: 10px;
        color: Palette.accent-background.transparentize(0.2);
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
    }
}

export component MessageBubble inherits VerticalLayout {
    in property <bool> is-own;
    in property <MessageEntry> msg;
    in property <length> available-width;

    callback open-media(string);
    callback save-file(SaveFileRequest);
    callback reply(string, string, string);

    property <color> own-bubble-color: Palette.accent-background.transparentize(0.4);
    property <color> other-bubble-color: Palette.alternate-background;
    property <length> bubble-max-width: available-width * 0.7;

    property <bool> is-service: msg.message-type == MessageKind.service;
    property <bool> is-plain-text: msg.message-type != MessageKind.image
        && msg.message-type != MessageKind.file
        && msg.message-type != MessageKind.utd
        && msg.message-type != MessageKind.unsupported;
    property <bool> has-remote-id: msg.event-id != "";

    if is-service: ServiceMessage {
        kind: msg.service-kind;
        actor: msg.sender;
        target: msg.service-target;
    }

    if !is-service: HorizontalLayout {
        alignment: is-own ? end : start;
        padding-left: is-own ? 0 : 8px;
        padding-right: is-own ? 8px : 0;
        padding-top: 2px;
        padding-bottom: 2px;

        if !is-own: Avatar {
            width: 32px;
            height: 32px;
            background: Avatars.color(msg.color-index);
            has-image: msg.has-avatar;
            image: msg.avatar;
            initial: msg.sender-initial;
            initial-size: 13px;
        }

        if !is-own: Rectangle {
            width: 6px;
        }

        Rectangle {
            max-width: bubble-max-width;
            height: bubble-content.preferred-height;
            background: is-own ? own-bubble-color : other-bubble-color;
            border-radius: 12px;

            hover-bg := TouchArea {
                width: 100%;
                height: 100%;
            }

            bubble-content := VerticalLayout {
                padding: 4px;
                padding-left: 10px;
                padding-right: 10px;

                if !is-own: HorizontalLayout {
                    alignment: start;
                    spacing: 4px;

                    Text {
                        text: msg.sender;
                        font-size: 12px;
                        font-weight: 700;
                        color: Palette.accent-background;
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    for pronoun in msg.pronouns: PronounBadge {
                        y: (parent.height - self.height) / 2;
                        text: pronoun;
                    }
                }

                if msg.has-reply: VerticalLayout {
                    padding-top: is-own ? 0 : 4px;

                    Rectangle {
                        height: reply-quote.preferred-height;
                        border-radius: 4px;
                        background: is-own
                            ? Palette.accent-background.transparentize(0.7)
                            : Palette.foreground.transparentize(0.92);

                        reply-quote := ReplyQuote {
                            padding: 4px;
                            sender: msg.reply-sender;
                            preview: MessagePreview.label(msg.reply-kind, msg.reply-body);
                        }
                    }
                }

                if msg.message-type == MessageKind.image: ImageMessage {
                    thumbnail: msg.thumbnail;
                    media-state: msg.media-state;
                    image-width: msg.image-width;
                    image-height: msg.image-height;
                    body: msg.body;
                    event-id: msg.event-id;
                    open-media(id) => {
                        root.open-media(id);
                    }
                }

                if msg.message-type == MessageKind.file: FileMessage {
                    body: msg.body;
                    event-id: msg.event-id;
                    save-file(req) => {
                        root.save-file(req);
                    }
                }

                if msg.message-type == MessageKind.utd: UtdMessage { }

                if msg.message-type == MessageKind.unsupported: UnsupportedMessage {
                    kind: msg.unsupported-kind;
                    body: msg.body;
                }

                if is-plain-text: TextMessage {
                    text: msg.body;
                }

                HorizontalLayout {
                    alignment: end;
                    spacing: 3px;

                    if msg.edited: IconDisplay {
                        y: (parent.height - self.height) / 2;
                        icon: IconSet.Pencil;
                        size: 11px;
                        stroke: Palette.foreground.transparentize(0.5);
                    }

                    Text {
                        text: msg.timestamp;
                        font-size: 12px;
                        color: Palette.foreground.transparentize(0.5);
                        horizontal-alignment: right;
                        vertical-alignment: center;
                    }
                }
            }

            reply-btn := ClickArea {
                x: parent.width - self.width - 6px;
                y: 4px;
                width: reply-pill.width;
                height: reply-pill.height;
                ring-radius: 11px;
                label: @tr("Reply to {}", msg.sender);
                enabled: root.has-remote-id;
                opacity: root.has-remote-id && (hover-bg.has-hover || self.has-hover || self.has-focus) ? 1 : 0;
                clicked => {
                    root.reply(msg.event-id, msg.sender, MessagePreview.label(msg.preview-kind, msg.body));
                }

                reply-pill := Rectangle {
                    width: reply-row.preferred-width;
                    height: 22px;
                    border-radius: 11px;
                    background: Palette.accent-background;
                    drop-shadow-blur: 4px;
                    drop-shadow-color: Palette.foreground.transparentize(0.7);

                    reply-row := HorizontalLayout {
                        alignment: center;
                        spacing: 4px;
                        padding-left: 8px;
                        padding-right: 8px;

                        IconDisplay {
                            width: 13px;
                            height: 13px;
                            y: (parent.height - self.height) / 2;
                            icon: IconSet.Reply;
                            size: 13px;
                            stroke: Palette.accent-foreground;
                        }

                        Text {
                            text: @tr("Reply");
                            font-size: 12px;
                            font-weight: 600;
                            vertical-alignment: center;
                            color: Palette.accent-foreground;
                        }
                    }
                }
            }
        }
    }
}
