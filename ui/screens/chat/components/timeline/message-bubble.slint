import {
    Palette,
} from "std-widgets.slint";
import { IconDisplay, IconSet } from "@lucide";

import {
    MessageEntry,
    SaveFileRequest,
} from "../types.slint";

import { MessagePreview } from "../message-preview.slint";
import { ServiceMessage } from "./messages/service-message.slint";
import { TextMessage } from "./messages/text-message.slint";
import { ImageMessage } from "./messages/image-message.slint";
import { FileMessage } from "./messages/file-message.slint";
import { UtdMessage } from "./messages/utd-message.slint";
import { UnsupportedMessage } from "./messages/unsupported-message.slint";
import { Avatars, Fonts } from "../../../../theme.slint";

export component MessageBubble inherits VerticalLayout {
    in property <bool> is-own;
    in property <MessageEntry> msg;
    in property <length> available-width;

    callback open-media(string);
    callback save-file(SaveFileRequest);
    callback reply(string, string, string);

    property <color> own-bubble-color: Palette.accent-background.transparentize(0.4);
    property <color> other-bubble-color: Palette.alternate-background;
    property <length> bubble-max-width: available-width * 0.7;

    if msg.message-type == "service": ServiceMessage {
        kind: msg.service-kind;
        actor: msg.sender;
        target: msg.service-target;
    }

    if msg.message-type != "service": HorizontalLayout {
        alignment: is-own ? end : start;
        padding-left: is-own ? 0 : 8px;
        padding-right: is-own ? 8px : 0;
        padding-top: 2px;
        padding-bottom: 2px;

        if !is-own: Rectangle {
            width: 32px;
            height: 32px;
            border-radius: 16px;
            clip: true;
            background: Avatars.color(msg.color-index);

            if msg.has-avatar: Image {
                source: msg.avatar;
                width: 32px;
                height: 32px;
                image-fit: cover;
            }

            if !msg.has-avatar: Text {
                width: 32px;
                height: 32px;
                text: msg.sender-initial;
                font-family: Fonts.emoji;
                font-size: 13px;
                font-weight: 600;
                horizontal-alignment: center;
                vertical-alignment: center;
                color: white;
                overflow: clip;
            }
        }

        if !is-own: Rectangle {
            width: 6px;
        }

        Rectangle {
            max-width: bubble-max-width;
            height: bubble-content.preferred-height;
            background: is-own ? own-bubble-color : other-bubble-color;
            border-radius: 12px;

            hover-bg := TouchArea {
                width: 100%;
                height: 100%;
            }

            bubble-content := VerticalLayout {
                padding: 4px;
                padding-left: 10px;
                padding-right: 10px;

                if !is-own: HorizontalLayout {
                    alignment: start;
                    spacing: 4px;

                    Text {
                        text: msg.sender;
                        font-size: 12px;
                        font-weight: 700;
                        color: Palette.accent-background;
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    for pronoun in msg.pronouns: Rectangle {
                        y: (parent.height - self.height) / 2;
                        width: pronoun-text.preferred-width + 10px;
                        height: pronoun-text.preferred-height + 2px;
                        border-radius: self.height / 2;
                        background: Palette.foreground.transparentize(0.92);

                        pronoun-text := Text {
                            text: pronoun;
                            font-size: 10px;
                            color: Palette.accent-background.transparentize(0.2);
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            overflow: elide;
                        }
                    }
                }

                if msg.has-reply: VerticalLayout {
                    padding-top: is-own ? 0 : 4px;

                    Rectangle {
                        height: reply-quote.preferred-height + 8px;
                        border-radius: 4px;
                        background: is-own
                            ? Palette.accent-background.transparentize(0.7)
                            : Palette.foreground.transparentize(0.92);

                        HorizontalLayout {
                            padding: 4px;
                            spacing: 6px;

                            Rectangle {
                                width: 3px;
                                border-radius: 1.5px;
                                background: Palette.accent-background;
                            }

                            reply-quote := VerticalLayout {
                                spacing: 1px;
                                alignment: center;

                                Text {
                                    text: msg.reply-sender;
                                    font-size: 12px;
                                    font-weight: 700;
                                    color: Palette.accent-background;
                                    overflow: elide;
                                }

                                Text {
                                    text: MessagePreview.label(msg.reply-kind, msg.reply-body);
                                    font-family: Fonts.emoji;
                                    font-size: 12px;
                                    color: Palette.foreground.transparentize(0.35);
                                    overflow: elide;
                                }
                            }
                        }
                    }
                }

                if msg.message-type == "image": ImageMessage {
                    thumbnail: msg.thumbnail;
                    has-thumbnail: msg.has-thumbnail;
                    image-width: msg.image-width;
                    image-height: msg.image-height;
                    body: msg.body;
                    event-id: msg.event-id;
                    open-media(id) => {
                        root.open-media(id);
                    }
                }

                if msg.message-type == "file": FileMessage {
                    body: msg.body;
                    event-id: msg.event-id;
                    save-file(req) => {
                        root.save-file(req);
                    }
                }

                if msg.message-type == "utd": UtdMessage { }

                if msg.message-type == "unsupported": UnsupportedMessage {
                    kind: msg.unsupported-kind;
                    body: msg.body;
                }

                if msg.message-type != "image" && msg.message-type != "file" && msg.message-type != "utd" && msg.message-type != "unsupported": TextMessage {
                    text: msg.body;
                }

                HorizontalLayout {
                    alignment: end;
                    spacing: 3px;

                    if msg.edited: IconDisplay {
                        y: (parent.height - self.height) / 2;
                        icon: IconSet.Pencil;
                        size: 11px;
                        stroke: Palette.foreground.transparentize(0.5);
                    }

                    Text {
                        text: msg.timestamp;
                        font-size: 12px;
                        color: Palette.foreground.transparentize(0.5);
                        horizontal-alignment: right;
                        vertical-alignment: center;
                    }
                }
            }

            reply-btn := TouchArea {
                x: parent.width - self.width - 6px;
                y: 4px;
                width: reply-pill.width;
                height: reply-pill.height;
                mouse-cursor: pointer;
                visible: hover-bg.has-hover || self.has-hover;
                clicked => {
                    root.reply(msg.event-id, msg.sender, MessagePreview.label(msg.preview-kind, msg.body));
                }

                reply-pill := Rectangle {
                    width: reply-row.preferred-width;
                    height: 22px;
                    border-radius: 11px;
                    background: Palette.accent-background;
                    drop-shadow-blur: 4px;
                    drop-shadow-color: Palette.foreground.transparentize(0.7);

                    reply-row := HorizontalLayout {
                        alignment: center;
                        spacing: 4px;
                        padding-left: 8px;
                        padding-right: 8px;

                        IconDisplay {
                            width: 13px;
                            height: 13px;
                            y: (parent.height - self.height) / 2;
                            icon: IconSet.Reply;
                            size: 13px;
                            stroke: Palette.accent-foreground;
                        }

                        Text {
                            text: @tr("Reply");
                            font-size: 12px;
                            font-weight: 600;
                            vertical-alignment: center;
                            color: Palette.accent-foreground;
                        }
                    }
                }
            }
        }
    }
}
