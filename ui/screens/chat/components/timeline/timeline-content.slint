import {
    ListView,
    Palette,
} from "std-widgets.slint";
import { IconDisplay, IconSet } from "@lucide";

import { SaveFileRequest } from "../types.slint";

import { MessageBubble } from "./message-bubble.slint";
import { MediaState, MessageKind } from "../../../../enums.slint";
import { ClickArea } from "../../../../components/a11y.slint";
import { RoomView } from "../../../../views.slint";

export component TimelineContent inherits Rectangle {
    in property <string> room-id: "";
    in property <length> available-width;

    callback open-media(string);
    callback save-file(SaveFileRequest);
    callback reply(string, string, string);
    callback request-media(string);
    callback scroll-position-changed(bool, bool);
    callback paginate-backwards();
    callback paginate-forwards();
    callback jump-to-latest();

    clip: true;

    property <length> content-height: 0;

    changed room-id => {
        flickable.reset-scroll();
    }

    if RoomView.backwards-loading: HorizontalLayout {
        x: 0;
        y: 0;
        width: parent.width;
        height: 32px;
        alignment: center;
        Text {
            text: @tr("Loading older messages...");
            font-size: 12px;
            color: Palette.foreground.transparentize(0.5);
        }
    }

    if RoomView.forwards-loading: HorizontalLayout {
        x: 0;
        y: parent.height - self.height;
        width: parent.width;
        height: 32px;
        alignment: center;
        Text {
            text: @tr("Loading newer messages...");
            font-size: 12px;
            color: Palette.foreground.transparentize(0.5);
        }
    }

    flickable := ListView {
        width: parent.width;
        height: root.content-height > 0 ? min(parent.height, root.content-height) : parent.height;
        y: parent.height - self.height;

        property <length> scroll-threshold: 40px;
        property <bool> auto-scroll: true;
        property <bool> programmatic-scroll: false;
        property <bool> settling: false;

        property <bool> was-at-top: false;
        property <bool> was-at-bottom: true;
        property <bool> at-top: self.viewport-y >= -self.scroll-threshold;
        property <bool> at-bottom:
            self.viewport-y <= -(self.max-scroll-y - self.scroll-threshold);

        property <int> seen-prepend-token: 0;
        property <length> prev-viewport-height: 0;
        property <length> prev-viewport-y: 0;
        property <int> prev-item-count: 0;

        property <length> max-scroll-y:
            self.viewport-height - self.visible-height;
        property <bool> scrollable:
            self.viewport-height > self.visible-height;
        property <int> item-count: RoomView.timeline.length;

        changed viewport-height => {
            root.content-height = self.viewport-height;
            if (self.settling || self.auto-scroll) && self.scrollable
                && self.viewport-y <= self.prev-viewport-y {
                self.scroll-to-bottom();
            } else if RoomView.prepend-token != self.seen-prepend-token
                && self.scrollable
                && self.prev-viewport-height > 0
                && self.prev-item-count > 0
                && self.item-count > self.prev-item-count {
                self.programmatic-scroll = true;
                self.viewport-y = self.anchor-viewport-y();
            }
            self.seen-prepend-token = RoomView.prepend-token;
            self.prev-viewport-height = self.viewport-height;
            self.prev-item-count = self.item-count;
        }

        changed viewport-y => {
            if self.programmatic-scroll {
                self.programmatic-scroll = false;
            } else {
                self.settling = false;
                if self.at-top && !self.was-at-top && !RoomView.backwards-loading {
                    root.paginate-backwards();
                }
                if self.at-bottom && !self.was-at-bottom && !RoomView.forwards-loading {
                    root.paginate-forwards();
                }
                if self.scrollable {
                    if self.viewport-y > self.prev-viewport-y {
                        self.auto-scroll = false;
                    } else if self.at-bottom {
                        self.auto-scroll = true;
                    }
                }
            }

            self.prev-viewport-y = self.viewport-y;

            if (self.at-top != self.was-at-top) || (self.at-bottom != self.was-at-bottom) {
                self.was-at-top = self.at-top;
                self.was-at-bottom = self.at-bottom;
                root.scroll-position-changed(self.at-top, self.at-bottom);
            }
        }

        changed item-count => {
            if self.auto-scroll {
                self.settling = true;
                self.scroll-to-bottom();
            }
        }

        function reset-scroll() {
            self.auto-scroll = true;
            self.settling = true;
            self.seen-prepend-token = RoomView.prepend-token;
            self.prev-viewport-height = 0;
            self.prev-viewport-y = 0;
            self.prev-item-count = 0;
            self.scroll-to-bottom();
        }

        function scroll-to-bottom() {
            self.programmatic-scroll = true;
            self.viewport-y = -max(self.max-scroll-y, 0px);
        }

        pure function anchor-viewport-y() -> length {
            -((-self.viewport-y / (self.prev-viewport-height / self.prev-item-count))
                + (self.item-count - self.prev-item-count))
                * (self.viewport-height / self.item-count)
        }

        for msg in RoomView.timeline: MessageBubble {
            is-own: msg.is-own;
            msg: msg;
            available-width: root.available-width;
            init => {
                if (msg.message-type == MessageKind.image && msg.media-state != MediaState.ready)
                    || (!msg.is-own && !msg.has-avatar) {
                    root.request-media(msg.unique-id);
                }
            }
            open-media(id) => {
                root.open-media(id);
            }
            save-file(req) => {
                root.save-file(req);
            }
            reply(id, sender, preview) => {
                root.reply(id, sender, preview);
            }
        }
    }

    if !flickable.auto-scroll && RoomView.timeline.length > 0: ClickArea {
        x: parent.width - self.width - 16px;
        y: parent.height - self.height - 16px;
        width: 40px;
        height: 40px;
        border-radius: 20px;
        ring-radius: 20px;
        background: Palette.alternate-background;
        label: @tr("Jump to latest messages");
        clicked => {
            flickable.scroll-to-bottom();
            flickable.auto-scroll = true;
            root.jump-to-latest();
        }

        IconDisplay {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            icon: IconSet.ChevronDown;
            size: 22px;
            stroke: Palette.alternate-foreground;
        }

        if RoomView.new-messages-count > 0: Rectangle {
            x: parent.width - self.width / 2 - 2px;
            y: -self.height / 2 + 2px;
            width: Math.max(18px, badge-text.preferred-width + 8px);
            height: 18px;
            border-radius: 9px;
            background: Palette.accent-background;

            badge-text := Text {
                text: RoomView.new-messages-count;
                font-size: 10px;
                font-weight: 700;
                color: Palette.accent-foreground;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }
}
