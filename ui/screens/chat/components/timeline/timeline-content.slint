import {
    ListView,
    Palette,
} from "std-widgets.slint";
import { IconDisplay, IconSet } from "@lucide";

import {
    MessageEntry,
    SaveFileRequest,
} from "../types.slint";

import { MessageBubble } from "./message-bubble.slint";

export component TimelineContent inherits Rectangle {
    in property <[MessageEntry]> timeline: [];
    in property <bool> backwards-loading: false;
    in property <int> new-messages-count: 0;
    in property <length> available-width;

    callback open-media(string);
    callback save-file(SaveFileRequest);
    callback reply(string, string, string);
    callback scroll-position-changed(bool, bool);
    callback jump-to-latest();

    clip: true;

    if root.backwards-loading: HorizontalLayout {
        x: 0;
        y: 0;
        width: parent.width;
        height: 32px;
        alignment: center;
        Text {
            text: @tr("Loading older messages...");
            font-size: 12px;
            color: Palette.foreground.transparentize(0.5);
        }
    }

    flickable := ListView {
        width: parent.width;
        height: parent.height;

        property <length> scroll-threshold: 40px;
        property <bool> auto-scroll: true;
        property <bool> programmatic-scroll: false;
        property <bool> settling: false;

        property <bool> was-at-top: false;
        property <bool> was-at-bottom: true;
        property <bool> at-top: self.viewport-y >= -self.scroll-threshold;
        property <bool> at-bottom:
            self.viewport-y <= -(self.max-scroll-y - self.scroll-threshold);

        property <int> prev-count: 0;
        property <bool> prepend-pending: false;
        property <length> saved-viewport-y: 0;
        property <int> saved-count: 0;

        property <length> max-scroll-y:
            self.viewport-height - self.visible-height;
        property <bool> scrollable:
            self.viewport-height > self.visible-height;
        property <int> item-count: root.timeline.length;
        property <bool> items-added:
            self.item-count > self.prev-count;

        changed viewport-height => {
            if self.settling && self.scrollable {
                self.scroll-to-bottom();
            }
        }

        changed viewport-y => {
            if self.programmatic-scroll {
                self.programmatic-scroll = false;
            } else {
                self.prepend-pending = false;
                self.settling = false;
            }

            if self.scrollable {
                self.auto-scroll = self.viewport-y <= -(self.max-scroll-y - self.scroll-threshold);
            }
            if (self.at-top != self.was-at-top) || (self.at-bottom != self.was-at-bottom) {
                self.was-at-top = self.at-top;
                self.was-at-bottom = self.at-bottom;
                root.scroll-position-changed(self.at-top, self.at-bottom);
            }
        }

        changed item-count => {
            if self.scrollable {
                if self.auto-scroll {
                    self.settling = true;
                    self.scroll-to-bottom();
                } else if self.items-added {
                    self.anchor-scroll();
                }
            }
            self.prev-count = self.item-count;
        }

        function scroll-to-bottom() {
            self.programmatic-scroll = true;
            self.viewport-y = -self.max-scroll-y;
        }

        function anchor-scroll() {
            if !self.prepend-pending {
                self.saved-viewport-y = self.viewport-y;
                self.saved-count = self.prev-count;
                self.prepend-pending = true;
            }
            self.programmatic-scroll = true;
            self.viewport-y = self.saved-viewport-y - self.viewport-height * (self.item-count - self.saved-count) / self.item-count;
        }

        for msg in root.timeline: MessageBubble {
            is-own: msg.is-own;
            msg: msg;
            available-width: root.available-width;
            open-media(id) => {
                root.open-media(id);
            }
            save-file(req) => {
                root.save-file(req);
            }
            reply(id, sender, preview) => {
                root.reply(id, sender, preview);
            }
        }
    }

    if !flickable.auto-scroll && root.timeline.length > 0: Rectangle {
        x: parent.width - self.width - 16px;
        y: parent.height - self.height - 16px;
        width: 40px;
        height: 40px;
        border-radius: 20px;
        background: Palette.alternate-background;

        IconDisplay {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            icon: IconSet.ChevronDown;
            size: 22px;
            stroke: Palette.alternate-foreground;
        }

        TouchArea {
            mouse-cursor: pointer;
            clicked => {
                flickable.viewport-y = -(flickable.viewport-height - flickable.visible-height);
                flickable.auto-scroll = true;
                root.jump-to-latest();
            }
        }

        if root.new-messages-count > 0: Rectangle {
            x: parent.width - self.width / 2 - 2px;
            y: -self.height / 2 + 2px;
            width: Math.max(18px, badge-text.preferred-width + 8px);
            height: 18px;
            border-radius: 9px;
            background: Palette.accent-background;

            badge-text := Text {
                text: root.new-messages-count;
                font-size: 10px;
                font-weight: 700;
                color: Palette.accent-foreground;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }
}
