import { Palette, Spinner } from "std-widgets.slint";
import { IconDisplay, IconSet } from "@lucide";
import { ClickArea } from "../../../../../components/a11y.slint";
import { MediaState } from "../../../../../enums.slint";

component MediaFrame inherits Rectangle {
    in property <float> aspect;

    width: min(400px, max(267px, 400px * self.aspect));
    height: min(400px, self.width / max(self.aspect, 0.01));
    background: Palette.alternate-background;
    border-radius: 4px;
}

export component ImageMessage inherits VerticalLayout {
    in property <image> thumbnail;
    in property <MediaState> media-state;
    in property <int> image-width;
    in property <int> image-height;
    in property <string> body;
    in property <string> event-id;

    property <bool> has-dimensions: root.image-width > 0 && root.image-height > 0;
    property <bool> is-ready: root.media-state == MediaState.ready;
    property <bool> is-failed: root.media-state == MediaState.failed;
    property <bool> is-loading: root.media-state == MediaState.idle && root.has-dimensions;
    property <bool> has-frame: root.is-ready || root.is-loading || root.is-failed;
    property <bool> is-text-only: root.media-state == MediaState.idle && !root.has-dimensions;
    property <float> frame-aspect: root.image-width / max(root.image-height, 1);
    property <bool> has-caption: root.body != "";

    callback open-media(string);

    if is-ready: ClickArea {
        enabled: root.event-id != "";
        label: root.has-caption ? @tr("Open image: {}", root.body) : @tr("Open image");
        ring-radius: 4px;
        width: thumb-img.width;
        height: thumb-img.height;
        clicked => {
            root.open-media(root.event-id);
        }

        thumb-img := Image {
            source: root.thumbnail;
            property <float> aspect: self.source.width / max(self.source.height, 1);
            width: min(400px, max(267px, 400px * aspect));
            height: min(400px, self.width / max(aspect, 0.01));
            image-fit: ImageFit.contain;
        }
    }

    if is-loading: MediaFrame {
        aspect: root.frame-aspect;
        Spinner {
            indeterminate: true;
        }
    }

    if is-failed: MediaFrame {
        aspect: root.has-dimensions ? root.frame-aspect : 1.5;

        VerticalLayout {
            alignment: center;
            spacing: 8px;

            HorizontalLayout {
                alignment: center;

                IconDisplay {
                    icon: IconSet.ImageOff;
                    size: 32px;
                    stroke: Palette.foreground.transparentize(0.5);
                }
            }

            Text {
                text: @tr("Image unavailable");
                font-size: 13px;
                color: Palette.foreground.transparentize(0.4);
                horizontal-alignment: center;
            }
        }
    }

    if is-text-only: Text {
        text: root.has-caption ? @tr("Image: {}", root.body) : @tr("Image");
        font-size: 14px;
        color: Palette.foreground.transparentize(0.3);
        wrap: word-wrap;
    }

    if has-frame && has-caption: Text {
        text: root.body;
        font-size: 14px;
        wrap: word-wrap;
    }
}
