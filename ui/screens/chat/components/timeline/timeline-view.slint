import { Palette, Button } from "std-widgets.slint";

import { SendMessageRequest, SaveFileRequest } from "../types.slint";

import { TimelineContent } from "./timeline-content.slint";
import { MessageInput } from "./message-input.slint";
import { Fonts } from "../../../../theme.slint";
import { TimelineState } from "../../../../enums.slint";
import { DirectoryView, RoomView } from "../../../../views.slint";

export component TimelineView inherits Rectangle {
    background: Palette.background;

    property <string> room-id: DirectoryView.selected-room-id;

    in-out property <string> input-message: "";
    in-out property <string> reply-event-id: "";
    in-out property <string> reply-sender: "";
    in-out property <string> reply-preview: "";

    callback send-message(SendMessageRequest);
    callback open-media(string);
    callback save-file(SaveFileRequest);
    callback request-media(string);
    callback scroll-position-changed(bool, bool);
    callback paginate-backwards();
    callback paginate-forwards();
    callback jump-to-latest();
    callback retry();

    property <length> header-height: 52px;
    property <length> message-input-height: 40px;
    property <length> reply-bar-height: 44px;
    property <length> input-height: root.reply-event-id != ""
        ? root.message-input-height + root.reply-bar-height
        : root.message-input-height;
    property <length> spacing: 8px;

    changed room-id => {
        root.input-message = "";
        root.reply-event-id = "";
        root.reply-sender = "";
        root.reply-preview = "";
    }

    if RoomView.selected-room-name == "": Text {
        text: @tr("Select a room");
        font-size: 16px;
        color: Palette.foreground.transparentize(0.5);
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    if RoomView.selected-room-name != "": Rectangle {
        x: 0;
        y: 0;
        width: root.width;
        height: root.header-height;
        background: Palette.alternate-background;

        VerticalLayout {
            x: 12px;
            width: parent.width - 24px;
            alignment: center;
            spacing: 1px;

            Text {
                text: RoomView.selected-room-name;
                font-family: Fonts.emoji;
                font-size: 16px;
                font-weight: 700;
                overflow: elide;
            }

            if RoomView.selected-room-members > 0: Text {
                text: @tr("{n} member" | "{n} members" % RoomView.selected-room-members);
                font-size: 12px;
                color: Palette.foreground.transparentize(0.45);
                overflow: elide;
            }
        }
    }

    if RoomView.selected-room-name != "" && RoomView.timeline.length == 0
        && (RoomView.timeline-status == TimelineState.loading
            || RoomView.timeline-status == TimelineState.failed
            || RoomView.timeline-status == TimelineState.disconnected): Rectangle {
        x: 0;
        y: root.header-height;
        width: root.width;
        height: root.height - root.header-height - root.input-height;

        VerticalLayout {
            alignment: center;
            spacing: 12px;

            Text {
                text: RoomView.timeline-status == TimelineState.loading
                    ? @tr("Loading messages...")
                    : RoomView.timeline-status == TimelineState.disconnected
                        ? @tr("Connection lost")
                        : @tr("Couldn't load messages");
                font-size: 14px;
                color: Palette.foreground.transparentize(0.5);
                horizontal-alignment: center;
            }

            if (RoomView.timeline-status == TimelineState.failed && RoomView.timeline-retryable)
                || RoomView.timeline-status == TimelineState.disconnected: HorizontalLayout {
                alignment: center;

                Button {
                    text: @tr("Retry");
                    clicked => {
                        root.retry();
                    }
                }
            }
        }
    }

    if RoomView.selected-room-name != "": TimelineContent {
        x: 0;
        y: root.header-height + root.spacing;
        width: root.width;
        height: root.height - root.header-height - root.input-height - root.spacing * 2;
        room-id: root.room-id;
        available-width: root.width;
        open-media(id) => {
            root.open-media(id);
        }
        save-file(req) => {
            root.save-file(req);
        }
        request-media(id) => {
            root.request-media(id);
        }
        reply(id, sender, preview) => {
            root.reply-event-id = id;
            root.reply-sender = sender;
            root.reply-preview = preview;
        }
        scroll-position-changed(at-top, at-bottom) => {
            root.scroll-position-changed(at-top, at-bottom);
        }
        paginate-backwards => {
            root.paginate-backwards();
        }
        paginate-forwards => {
            root.paginate-forwards();
        }
        jump-to-latest => {
            root.jump-to-latest();
        }
    }

    if RoomView.selected-room-name != "": MessageInput {
        x: 0;
        y: root.height - self.height;
        width: root.width;
        room-id: root.room-id;
        message <=> root.input-message;
        reply-event-id <=> root.reply-event-id;
        reply-sender <=> root.reply-sender;
        reply-preview <=> root.reply-preview;
        send-message(req) => {
            root.send-message(req);
        }
    }
}
