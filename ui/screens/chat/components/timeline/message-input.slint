import {
    Palette,
} from "std-widgets.slint";
import { IconDisplay, IconSet } from "@lucide";

import { SendMessageRequest, EmojiInsert } from "../types.slint";
import { EmojiPicker, EmojiStore } from "./emoji-picker.slint";
import { Fonts } from "../../../../theme.slint";

export component MessageInput inherits Rectangle {
    in property <string> room-id;
    in-out property <string> message: "";
    in-out property <string> reply-event-id: "";
    in-out property <string> reply-sender: "";
    in-out property <string> reply-preview: "";

    callback send-message(SendMessageRequest);

    property <bool> picker-open: false;
    property <int> caret: 0;
    property <EmojiInsert> pending-insert;
    property <length> input-row-height: 40px;

    background: Palette.alternate-background;
    height: layout.preferred-height;

    function submit() {
        if root.message != "" {
            root.send-message({
                room-id: root.room-id,
                body: root.message,
                reply-to: root.reply-event-id,
            });
            root.message = "";
            root.clear-reply();
        }
    }

    function clear-reply() {
        root.reply-event-id = "";
        root.reply-sender = "";
        root.reply-preview = "";
    }

    if root.picker-open: TouchArea {
        x: 0;
        y: -1200px;
        width: root.width;
        height: 1200px;
        clicked => {
            root.picker-open = false;
        }
    }

    if root.picker-open: EmojiPicker {
        width: min(root.width - 16px, 360px);
        x: root.width - self.width - 8px;
        y: -self.height - 8px;
        height: 380px;
        picked(glyph) => {
            root.insert-at-caret(glyph);
        }
    }

    function insert-at-caret(glyph: string) {
        root.pending-insert = EmojiStore.insert(root.message, root.caret, glyph);
        root.message = root.pending-insert.text;
        root.caret = root.pending-insert.caret;
        text-input.focus();
        text-input.set-selection-offsets(root.pending-insert.caret, root.pending-insert.caret);
    }

    layout := VerticalLayout {
        if root.reply-event-id != "": Rectangle {
            height: 44px;
            background: Palette.background.transparentize(0.3);

            HorizontalLayout {
                padding-left: 12px;
                padding-right: 8px;
                padding-top: 6px;
                padding-bottom: 6px;
                spacing: 8px;

                Rectangle {
                    width: 3px;
                    background: Palette.accent-background;
                    border-radius: 1.5px;
                }

                VerticalLayout {
                    horizontal-stretch: 1;
                    alignment: center;
                    spacing: 1px;

                    Text {
                        text: @tr("Reply to {}", root.reply-sender);
                        font-size: 12px;
                        font-weight: 700;
                        color: Palette.accent-background;
                        overflow: elide;
                    }

                    Text {
                        text: root.reply-preview;
                        font-family: Fonts.emoji;
                        font-size: 12px;
                        color: Palette.foreground.transparentize(0.4);
                        overflow: elide;
                    }
                }

                cancel-reply-touch := TouchArea {
                    width: 28px;
                    mouse-cursor: pointer;
                    accessible-role: button;
                    accessible-label: @tr("Cancel reply");
                    clicked => {
                        root.clear-reply();
                    }

                    IconDisplay {
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        icon: IconSet.X;
                        size: 16px;
                        stroke: Palette.foreground.transparentize(0.4);
                    }
                }
            }
        }

        HorizontalLayout {
        height: root.input-row-height;
        padding-left: 12px;
        padding-right: 12px;

        Rectangle {
            horizontal-stretch: 1;

            text-input := TextInput {
                text <=> root.message;
                color: Palette.foreground;
                font-family: Fonts.emoji;
                font-size: 14px;
                vertical-alignment: center;
                accepted => {
                    root.submit();
                }
                edited => {
                    root.caret = self.cursor-position-byte-offset;
                }
                cursor-position-changed(pos) => {
                    root.caret = self.cursor-position-byte-offset;
                }
            }

            if root.message == "": Text {
                x: 0;
                y: 0;
                width: parent.width;
                height: parent.height;
                text: @tr("Send a message...");
                color: Palette.foreground.transparentize(0.5);
                font-size: 14px;
                vertical-alignment: center;
                horizontal-alignment: left;
            }
        }

        emoji-touch := TouchArea {
            width: 44px;
            mouse-cursor: pointer;
            accessible-role: button;
            accessible-label: @tr("Emoji");
            clicked => {
                root.picker-open = !root.picker-open;
            }

            IconDisplay {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                icon: IconSet.Smile;
                size: 20px;
                stroke: root.picker-open
                    ? Palette.accent-background
                    : Palette.foreground.transparentize(0.4);
            }
        }

        send-touch := TouchArea {
            width: 44px;
            mouse-cursor: root.message != "" ? pointer : default;
            accessible-role: button;
            accessible-label: @tr("Send");
            clicked => {
                root.submit();
            }

            IconDisplay {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                icon: IconSet.SendHorizontal;
                size: 20px;
                stroke: root.message != ""
                    ? Palette.accent-background
                    : Palette.foreground.transparentize(0.6);
            }
        }
        }
    }
}
