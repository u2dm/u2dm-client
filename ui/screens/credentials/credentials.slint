import {
    Button,
    LineEdit,
} from "std-widgets.slint";

import { LoginRequest } from "./types.slint";

export component CredentialsScreen inherits VerticalLayout {
    alignment: center;
    padding: 24px;
    spacing: 8px;

    in property <string> resolved-homeserver: "";
    in property <string> login-method: "";
    in property <string> login-status: "";
    in property <string> login-error: "";
    in-out property <string> input-username: "";
    in-out property <string> input-password: "";

    callback login-password(LoginRequest);
    callback login-oauth();
    callback back();

    function status-text(id: string) -> string {
        if (id == "logging-in") { return @tr("Logging in..."); }
        if (id == "opening-browser") { return @tr("Opening browser..."); }
        if (id == "waiting-auth") { return @tr("Waiting for authentication..."); }
        return id;
    }

    Text {
        text: @tr("U2DM");
        font-size: 32px;
        horizontal-alignment: center;
    }

    Text {
        text: @tr("Server: {}", root.resolved-homeserver);
        font-size: 14px;
        horizontal-alignment: center;
    }

    if root.login-method == "password" || root.login-method == "both": VerticalLayout {
        spacing: 8px;

        HorizontalLayout {
            alignment: center;

            LineEdit {
                text <=> root.input-username;
                placeholder-text: @tr("Username");
                horizontal-stretch: 0;
                max-width: root.width;
            }
        }

        HorizontalLayout {
            alignment: center;

            LineEdit {
                text <=> root.input-password;
                placeholder-text: @tr("Password");
                input-type: password;
                horizontal-stretch: 0;
                max-width: root.width;
            }
        }

        HorizontalLayout {
            alignment: center;

            Button {
                text: @tr("Log in");
                max-width: root.width;
                clicked => {
                    root.login-password({
                        homeserver: root.resolved-homeserver,
                        username: root.input-username,
                        password: root.input-password,
                    });
                }
            }
        }
    }

    if root.login-method == "oauth" || root.login-method == "both": HorizontalLayout {
        alignment: center;

        Button {
            text: @tr("Log in with browser");
            clicked => {
                root.login-oauth();
            }
        }
    }

    HorizontalLayout {
        alignment: center;

        Button {
            text: @tr("Back");
            clicked => {
                root.back();
            }
        }
    }

    if root.login-status != "": Text {
        text: root.status-text(root.login-status);
        font-size: 13px;
        horizontal-alignment: center;
    }

    if root.login-error != "": Text {
        text: root.login-error;
        color: red;
        font-size: 13px;
        horizontal-alignment: center;
    }
}
