import { LoginRequest } from "screens/credentials/types.slint";
import {
    RoomEntry,
    SpaceEntry,
    MessageEntry,
    SendMessageRequest,
    SaveFileRequest,
} from "screens/chat/components/types.slint";
import { VerificationEmoji } from "components/types.slint";

import { LoadingScreen } from "screens/loading.slint";
import { HomeserverScreen } from "screens/homeserver/homeserver.slint";
import { CredentialsScreen } from "screens/credentials/credentials.slint";
import { ChatScreen } from "screens/chat/chat.slint";
import { VerificationDialog } from "components/verification.slint";

export component AppWindow inherits Window {
    title: @tr("UTDM Matrix Client");
    preferred-width: root.width;
    preferred-height: root.height;

    in-out property <string> input-homeserver: "matrix.org";
    in-out property <string> login-status: "";
    in-out property <string> login-error: "";
    in-out property <string> login-step: "loading";
    in-out property <string> login-method: "";
    in-out property <string> resolved-homeserver: "";
    in-out property <string> input-username: "";
    in-out property <string> input-password: "";
    in-out property <string> user-id: "";
    in-out property <[RoomEntry]> rooms: [];
    in-out property <[SpaceEntry]> spaces: [];
    in-out property <[MessageEntry]> timeline: [];
    in-out property <string> selected-room-name: "";
    in-out property <string> selected-room-id: "";
    in-out property <string> selected-space-id: "";
    in-out property <string> connection-status: "disconnected";

    in-out property <bool> verification-visible: false;
    in-out property <string> verification-step: "";
    in-out property <string> verification-sender: "";
    in-out property <bool> verification-is-self: false;
    in-out property <[VerificationEmoji]> verification-emojis: [];
    in-out property <string> verification-error: "";
    in-out property <string> toast-message: "";
    in-out property <string> saved-file-path: "";
    in-out property <bool> timeline-loading: false;
    in-out property <int> new-messages-count: 0;
    in-out property <bool> backwards-loading: false;

    callback check-server(string);
    callback login-password(LoginRequest);
    callback login-oauth();
    callback select-room(string);
    callback select-space(string);
    callback move-space(int, int);
    callback send-message(SendMessageRequest);
    callback open-media(string);
    callback save-file(SaveFileRequest);
    callback logout();
    callback accept-verification();
    callback confirm-verification();
    callback reject-verification();
    callback scroll-position-changed(bool, bool);
    callback paginate-backwards();
    callback jump-to-latest();

    in-out property <string> input-message: "";

    if root.login-step == "loading": LoadingScreen {
        loading-status: root.login-status;
        loading-error: root.login-error;
    }

    if root.login-step == "homeserver": HomeserverScreen {
        input-homeserver <=> root.input-homeserver;
        login-status: root.login-status;
        login-error: root.login-error;
        check-server(hs) => {
            root.check-server(hs);
        }
    }

    if root.login-step == "credentials": CredentialsScreen {
        resolved-homeserver: root.resolved-homeserver;
        login-method: root.login-method;
        login-status: root.login-status;
        login-error: root.login-error;
        input-username <=> root.input-username;
        input-password <=> root.input-password;
        login-password(req) => {
            root.login-password(req);
        }
        login-oauth() => {
            root.login-oauth();
        }
        back => {
            root.login-step = "homeserver";
            root.login-error = "";
            root.login-status = "";
        }
    }

    if root.login-step == "logged-in": ChatScreen {
        user-id: root.user-id;
        connection-status: root.connection-status;
        rooms: root.rooms;
        spaces: root.spaces;
        timeline: root.timeline;
        timeline-loading: root.timeline-loading;
        new-messages-count: root.new-messages-count;
        backwards-loading: root.backwards-loading;
        toast-message: root.toast-message;
        saved-file-path: root.saved-file-path;
        selected-room-id <=> root.selected-room-id;
        selected-room-name <=> root.selected-room-name;
        selected-space-id <=> root.selected-space-id;
        input-message <=> root.input-message;
        select-room(id) => {
            root.select-room(id);
        }
        select-space(id) => {
            root.select-space(id);
        }
        move-space(from, to) => {
            root.move-space(from, to);
        }
        logout => {
            root.logout();
        }
        send-message(req) => {
            root.send-message(req);
        }
        open-media(id) => {
            root.open-media(id);
        }
        save-file(req) => {
            root.save-file(req);
        }
        dismiss-toast => {
            root.toast-message = "";
        }
        scroll-position-changed(at-top, at-bottom) => {
            root.scroll-position-changed(at-top, at-bottom);
        }
        paginate-backwards => {
            root.paginate-backwards();
        }
        jump-to-latest => {
            root.jump-to-latest();
        }
    }

    if root.verification-visible && root.login-step == "logged-in": VerificationDialog {
        verification-step: root.verification-step;
        verification-sender: root.verification-sender;
        verification-is-self: root.verification-is-self;
        verification-emojis: root.verification-emojis;
        verification-error: root.verification-error;
        accept-verification => {
            root.accept-verification();
        }
        confirm-verification => {
            root.confirm-verification();
        }
        reject-verification => {
            root.reject-verification();
        }
        dismissed => {
            root.verification-visible = false;
        }
    }
}
