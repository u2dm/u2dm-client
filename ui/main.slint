import {
    Button,
    LineEdit,
    ListView,
    Palette,
    VerticalBox,
} from "std-widgets.slint";

struct LoginRequest {
    homeserver: string,
    username: string,
    password: string,
}

struct RoomEntry {
    id: string,
    name: string,
    unread: int,
}

struct MessageEntry {
    sender: string,
    body: string,
    timestamp: string,
}

struct SendMessageRequest {
    room-id: string,
    body: string,
}

export component AppWindow inherits Window {
    title: "U2DM Matrix Client";
    preferred-width: root.width;
    preferred-height: root.height;

    in-out property <string> input-homeserver: "matrix.org";
    in-out property <string> login-status: "";
    in-out property <string> login-error: "";
    in-out property <string> login-step: "homeserver";
    in-out property <string> login-method: "";
    in-out property <string> resolved-homeserver: "";
    in-out property <string> input-username: "";
    in-out property <string> input-password: "";
    in-out property <string> user-id: "";
    in-out property <[RoomEntry]> rooms: [];
    in-out property <[MessageEntry]> timeline: [];
    in-out property <string> selected-room-name: "";
    in-out property <string> selected-room-id: "";
    in-out property <string> connection-status: "disconnected";

    callback check-server(string);
    callback login-password(LoginRequest);
    callback login-oauth(string);
    callback select-room(string);
    callback send-message(SendMessageRequest);
    callback logout();

    in-out property <string> input-message: "";

    pure function status-indicator-color(status: string) -> color {
        if status == "connected" {
            return Palette.accent-background;
        }
        if status == "connecting" {
            return Palette.accent-background.transparentize(0.5);
        }
        if status == "error" {
            return Palette.foreground.mix(Colors.red, 0.6);
        }
        return Palette.border;
    }

    if root.login-step == "homeserver": VerticalLayout {
        alignment: center;
        padding: 24px;
        spacing: 12px;

        Text {
            text: "U2DM";
            font-size: 32px;
            horizontal-alignment: center;
        }

        HorizontalLayout {
            alignment: center;

            LineEdit {
                text <=> root.input-homeserver;
                placeholder-text: "Homeserver";
                horizontal-stretch: 0;
                max-width: 320px;
            }
        }

        HorizontalLayout {
            alignment: center;

            Button {
                text: "Continue";
                max-width: 320px;
                clicked => {
                    root.check-server(root.input-homeserver);
                }
            }
        }

        if root.login-status != "": Text {
            text: root.login-status;
            font-size: 13px;
            horizontal-alignment: center;
        }

        if root.login-error != "": Text {
            text: root.login-error;
            color: red;
            font-size: 13px;
            horizontal-alignment: center;
        }
    }

    if root.login-step == "credentials": VerticalLayout {
        alignment: center;
        padding: 24px;
        spacing: 8px;

        Text {
            text: "U2DM";
            font-size: 32px;
            horizontal-alignment: center;
        }

        Text {
            text: "Server: " + root.resolved-homeserver;
            font-size: 14px;
            horizontal-alignment: center;
        }

        if root.login-method == "password" || root.login-method == "both": VerticalLayout {
            spacing: 8px;

            HorizontalLayout {
                alignment: center;

                LineEdit {
                    text <=> root.input-username;
                    placeholder-text: "Username";
                    horizontal-stretch: 0;
                    max-width: root.width;
                }
            }

            HorizontalLayout {
                alignment: center;

                LineEdit {
                    text <=> root.input-password;
                    placeholder-text: "Password";
                    input-type: password;
                    horizontal-stretch: 0;
                    max-width: root.width;
                }
            }

            HorizontalLayout {
                alignment: center;

                Button {
                    text: "Log in";
                    max-width: root.width;
                    clicked => {
                        root.login-password({
                            homeserver: root.resolved-homeserver,
                            username: root.input-username,
                            password: root.input-password,
                        });
                    }
                }
            }
        }

        if root.login-method == "oauth" || root.login-method == "both": HorizontalLayout {
            alignment: center;

            Button {
                text: "Log in with browser";
                clicked => {
                    root.login-oauth(root.resolved-homeserver);
                }
            }
        }

        HorizontalLayout {
            alignment: center;

            Button {
                text: "Back";
                clicked => {
                    root.login-step = "homeserver";
                    root.login-error = "";
                    root.login-status = "";
                }
            }
        }

        if root.login-status != "": Text {
            text: root.login-status;
            font-size: 13px;
            horizontal-alignment: center;
        }

        if root.login-error != "": Text {
            text: root.login-error;
            color: red;
            font-size: 13px;
            horizontal-alignment: center;
        }
    }

    if root.login-step == "logged-in": HorizontalLayout {
        // room list
        VerticalLayout {
            width: 260px;
            padding: 8px;
            spacing: 4px;

            HorizontalLayout {
                spacing: 8px;
                padding-left: 8px;
                padding-right: 8px;

                Rectangle {
                    width: 10px;
                    height: 10px;
                    border-radius: 5px;
                    background: root.status-indicator-color(root.connection-status);
                }

                Text {
                    text: root.user-id;
                    font-size: 12px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    color: Palette.foreground.transparentize(0.5);
                }

                Button {
                    text: "Logout";
                    clicked => {
                        root.logout();
                    }
                }
            }

            ListView {
                for room in root.rooms: Rectangle {
                    height: 44px;
                    background: room.id == root.selected-room-id ? Palette.alternate-background : transparent;
                    border-radius: 4px;

                    TouchArea {
                        clicked => {
                            root.selected-room-name = room.name;
                            root.selected-room-id = room.id;
                            root.select-room(room.id);
                        }
                    }

                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 12px;
                        spacing: 8px;

                        Text {
                            text: room.name;
                            font-size: 14px;
                            vertical-alignment: center;
                            overflow: elide;
                        }

                        if room.unread > 0: Text {
                            text: "(" + room.unread + ")";
                            font-size: 12px;
                            vertical-alignment: center;
                            color: Palette.foreground.transparentize(0.5);
                        }
                    }
                }
            }
        }

        // timeline
        VerticalLayout {
            padding: 12px;
            spacing: 8px;

            if root.selected-room-name != "": Text {
                text: root.selected-room-name;
                font-size: 18px;
                font-weight: 700;
            }

            if root.selected-room-name == "": Text {
                text: "Select a room";
                font-size: 16px;
                color: Palette.foreground.transparentize(0.5);
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            if root.selected-room-name != "": ListView {
                for msg in root.timeline: Rectangle {
                    height: 48px;

                    VerticalLayout {
                        padding-left: 8px;
                        padding-right: 8px;
                        spacing: 2px;

                        HorizontalLayout {
                            spacing: 8px;

                            Text {
                                text: msg.sender;
                                font-size: 13px;
                                font-weight: 600;
                            }

                            Text {
                                text: msg.timestamp;
                                font-size: 11px;
                                color: Palette.foreground.transparentize(0.5);
                                vertical-alignment: center;
                            }
                        }

                        Text {
                            text: msg.body;
                            font-size: 14px;
                            overflow: elide;
                        }
                    }
                }
            }

            if root.selected-room-name != "": HorizontalLayout {
                spacing: 8px;

                LineEdit {
                    text <=> root.input-message;
                    placeholder-text: "Send a message...";
                    accepted => {
                        if root.input-message != "" {
                            root.send-message({ room-id: root.selected-room-id, body: root.input-message });
                            root.input-message = "";
                        }
                    }
                }

                Button {
                    text: "Send";
                    max-width: 80px;
                    clicked => {
                        if root.input-message != "" {
                            root.send-message({ room-id: root.selected-room-id, body: root.input-message });
                            root.input-message = "";
                        }
                    }
                }
            }
        }
    }
}
